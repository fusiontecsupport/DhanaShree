                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="ChitDuration" name="ChitDuration" value="@Model.chitscheme[0].ChitDuration" class="form-control ChitDuration" required placeholder="Duration" maxlength="50" tabindex="2" />
