                                                    <input type="checkbox" style="width:30px;" id="ReGenPatrnOpt" name="ReGenPatrnOpt" class="ReGenPatrnOpt" tabindex="2" onchange="Chk(this);" />
                                                    <input type="text" id="boolReGen" name="boolReGen" value="0" class="form-control boolReGen hide" tabindex="2" />
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label>Book Verification <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("BookVerificationTypeId", null, "Please select", new { @class = "form-control select2 custom-select  BookVerificationTypeId", @data_val = "true", @required = "required", @id = "BookVerificationTypeId", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Book Verification !!
                                                    </div>
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="ForemanPrizeInstalment">Prize Install.</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="ForemanPrizeInstalment" name="ForemanPrizeInstalment" value="@Model.chitscheme[0].ForemanPrizeInstalment" class="form-control ForemanPrizeInstalment" placeholder="Prize Install" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="ForemanPrizeInstalment" name="ForemanPrizeInstalment" class="form-control ForemanPrizeInstalment" placeholder="Prize Install" maxlength="50" tabindex="2" />

                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="CommissionEmp">Commission Emp (%)<span class="text-danger">*</span></label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="CommissionEmp" name="CommissionEmp" value="@Model.chitscheme[0].CommissionEmp" class="form-control CommissionEmp" required placeholder="Commission Emp" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Commission Emp !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="CommissionEmp" name="CommissionEmp" class="form-control CommissionEmp" required placeholder="Commission Emp" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Commission Emp !!
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="SubscriptionAmount">Subscription (₹)</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="SubscriptionAmount" readonly name="SubscriptionAmount" value="@Model.chitscheme[0].SubscriptionAmount" class="form-control SubscriptionAmount" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="SubscriptionAmount" name="SubscriptionAmount" readonly value="@ViewBag.SubscriptionAmount" class="form-control SubscriptionAmount" maxlength="50" tabindex="2" />

                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">

                                                    <label>Status <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("StatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  StatusTypeID", @data_val = "true", @required = "required", @id = "StatusTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Status !!
                                                    </div>
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="AmountCodeID">Amount Code <span class="text-danger">*</span></label>

                                                    @Html.DropDownList("AmountCodeID", null, "Please select Amount Code", new { @class = "form-control select2 custom-select  AmountCodeID", @data_val = "true", @id = "AmountCodeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Amount Code !!
                                                    </div>

                                                </div>

                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="BidCapAmount">Bid Cap (%)</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="BidCapAmount" name="BidCapAmount" value="@Model.chitscheme[0].BidCapAmount" class="form-control BidCapAmount" placeholder="Bid Cap (%)" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="BidCapAmount" name="BidCapAmount" class="form-control BidCapAmount" placeholder="Bid Cap (%)" maxlength="50" tabindex="2" />

                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="CommissionNonEmp">Non Emp (%)<span class="text-danger">*</span></label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="CommissionNonEmp" name="CommissionNonEmp" value="@Model.chitscheme[0].CommissionNonEmp" class="form-control CommissionNonEmp" placeholder="Non Emp" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Non Emp !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="CommissionNonEmp" name="CommissionNonEmp" class="form-control CommissionNonEmp" placeholder="Non Emp" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Non Emp !!
                                                        </div>
                                                    }
                                                </div>




                                                <div class="col-md-2 mb-2 hide">
                                                    <label>Ascertainment <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("AscertainmentTypeId", null, "Please select Auction", new { @class = "form-control select2 custom-select  AscertainmentTypeId", @data_val = "true", @id = "AscertainmentTypeId", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Auction !!
                                                    </div>
                                                </div>


                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-2 mb-2 hide">
                                                    <label>Collection Frequency <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("AscertainmentFrequencyTypeId", null, "Please select Frequency", new { @readonly = "readonly", @class = "form-control select2 custom-select  AscertainmentFrequencyTypeId", @data_val = "true", @id = "AscertainmentFrequencyTypeId", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Frequency !!
                                                    </div>
                                                </div>



                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="AverageDiscount">Avg. Discount (%)</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="AverageDiscount" readonly name="AverageDiscount" value="@Model.chitscheme[0].AverageDiscount" class="form-control AverageDiscount" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="AverageDiscount" name="AverageDiscount" readonly class="form-control AverageDiscount" value="@ViewBag.AverageDiscount" maxlength="50" tabindex="2" />

                                                    }
                                                </div>

                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="AverageDiscountAmount">Avg. Discount Amount</label>
                                                    <input type="number" id="AverageDiscountAmount" name="AverageDiscountAmount" value="@ViewBag.AverageDiscountAmount" readonly class="form-control AverageDiscountAmount" maxlength="50" tabindex="2" />
                                                </div>

                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="AverageDivident">Avg. Dividend (%)</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="AverageDivident" readonly name="AverageDivident" value="@Model.chitscheme[0].AverageDivident" class="form-control AverageDivident" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="AverageDivident" name="AverageDivident" value="@ViewBag.AverageDivident" readonly class="form-control AverageDivident" maxlength="50" tabindex="2" />

                                                    }
                                                </div>

                                                <div class="col-md-1 hide">
                                                    <label for="AverageDividentAmount">Avg. Dividend Amount</label>
                                                    <input type="number" id="AverageDividentAmount" name="AverageDividentAmount" value="@ViewBag.AverageDividentAmount" readonly class="form-control AverageDividentAmount" maxlength="50" tabindex="2" />

                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">



                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="EligibilityAmount">Eligibility Amount (₹)</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="EligibilityAmount" readonly name="EligibilityAmount" value="@Model.chitscheme[0].EligibilityAmount" class="form-control EligibilityAmount" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="EligibilityAmount" name="EligibilityAmount" readonly class="form-control EligibilityAmount" maxlength="50" tabindex="2" />

                                                    }
                                                </div>

                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="SubscriberReturns">Subscriber Returns (%)</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="SubscriberReturns" readonly name="SubscriberReturns" value="@Model.chitscheme[0].SubscriberReturns" class="form-control SubscriberReturns" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="SubscriberReturns" name="SubscriberReturns" readonly class="form-control SubscriberReturns" maxlength="50" tabindex="2" />

                                                    }
                                                </div>




                                            </div>
                                            <div class="col-12">
                                                <div class="d-md-flex align-items-center mt-3">

                                                    <a href="@Url.Action("Index", "ChitSchemeManagement")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>

                                                    <div class="ms-auto mt-3 mt-md-1 pull-right">
                                                        <button id="btnsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane p-3" id="profile2" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <div class="card-body">
                                            <form action="@Url.Content("~/ChitSchemeManagement/SaveSPData")" method="post" data-flag="0" class="needs-validation SchemePatternform" id="SchemePatternform" name="SchemePatternform" novalidate onsubmit="return ValidateSchemePatternform(this,event);">
                                                <div class="row">
                                                    <div class="col-lg-3 hide">
                                                        <div class="form-group">
                                                            <label>primary</label>
                                                            <input class="form-control" id="ChitSchemeID" value="@ViewBag.ChitSchemeID" name="ChitSchemeID" />
                                                        </div>
                                                    </div>
                                                    <input type="text" id="SMTDETAILIDX" value="0" name="SMTDETAILIDX" class="SMTDETAILIDX hide" />



                                                    <table class='table table-striped table-bordered bootstrap-datatable' id="SMTDETAIL">
                                                        <thead>
                                                            <tr>
                                                                <th><label>Install No<span class="required-field"></span></label></th>
                                                                <th><label>Subs.Amt</label></th>
                                                                <th><label>Due.Amt</label></th>
                                                                <th><label>Divident (%)</label></th>
                                                                <th><label>Divident (₹)</label></th>
                                                                <th><label>Discount (%)</label></th>
                                                                <th><label>Discount (₹)</label></th>
                                                                <th><label>Prize Amt. (₹)</label></th>
                                                                <th class="hide"> <a class="btn btn-success btn-sm" href="#" id="smadd_detail"><i class="fa fa-plus-square" style="color:white"></i></a></th>

                                                            </tr>
                                                        </thead>
                                                        <tbody class="SMTDETAIL_BODY" id="SMTDETAIL_BODY">
                                                            @if (Model.chitschemepatterns.Count > 0)
                                                            {
                                                                var order = 0;
                                                                foreach (ChitSchemePattern details in Model.chitschemepatterns)
                                                                {
                                                                    order = ++order;
                                                                    <tr class="item-row">

                                                                        <td class="col-md-1">
                                                                            <input type="text" id="PatternID" class="PatternID hide" name="PatternID" value="@details.PatternID" />
                                                                            <input id="ChitInstalmentNo" type="number" readonly value="@details.ChitInstalmentNo" name="ChitInstalmentNo" class="form-control ChitInstalmentNo" required />
                                                                        </td>
                                                                        <td class="col-md-2">

                                                                            <input id="DtlSubsAmt" readonly type="number" min="0.00" step="0.01" value="@ViewBag.SubscriptionAmount" name="DtlSubsAmt" class="form-control DtlDueAmt" />
                                                                        </td>
                                                                        <td class="col-md-2">

                                                                            <input id="DtlDueAmt" readonly type="number" min="0.00" step="0.01" name="DtlDueAmt" class="form-control DtlDueAmt" />
                                                                        </td>
                                                                        <td class="col-md-1">

                                                                            <input id="DividentPercentage" min="0.00" step="0.01" type="number" value="@details.DividentPercentage" name="DividentPercentage" onchange="CalcDividentAmt(this);" class="form-control DividentPercentage" />
                                                                        </td>

                                                                        <td class="col-md-2">

                                                                            <input id="DividentAmount" min="0.00" step="0.01" type="number" value="@details.DividentAmount" name="DividentAmount" readonly class="form-control DividentAmount" />
                                                                        </td>
                                                                        <td class="col-md-1">

                                                                            <input id="DiscountPercentage" min="0.00" step="0.01" type="number" value="@details.DiscountPercentage" name="DiscountPercentage" onchange="CalcDiscountAmt(this);" class="form-control DiscountPercentage" />
                                                                        </td>

                                                                        <td class="col-md-1">

                                                                            <input id="DiscountAmount" min="0.00" step="0.01" type="number" value="@details.DiscountAmount" name="DiscountAmount" readonly class="form-control DiscountAmount" />
                                                                        </td>
                                                                        <td class="col-md-2">

                                                                            <input id="DtlPrzAmt" type="number" min="0.00" step="0.01" name="DtlPrzAmt" readonly class="form-control DtlPrzAmt" />
