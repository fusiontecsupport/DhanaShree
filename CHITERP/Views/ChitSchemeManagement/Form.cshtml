                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="InitialDividend" name="InitialDividend" class="form-control InitialDividend" placeholder="Initial Dividend" maxlength="50" tabindex="2" />

                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="SealingPeriod">Sealing Period</label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="SealingPeriod" name="SealingPeriod" value="@Model.chitscheme[0].SealingPeriod" class="form-control SealingPeriod" placeholder="Sealing Period" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="SealingPeriod" name="SealingPeriod" class="form-control SealingPeriod" placeholder="Sealing Period" maxlength="50" tabindex="2" />

                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
