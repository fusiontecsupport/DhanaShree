@using CHITERP.Models;
@model CHITERP.Models.ChitSchemeList

@{
    ViewBag.Title = "Chit Scheme";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .spacer5 {
        height: 15px;
    }
    /*   body {
        font-family: Arial !important;
    }*/
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">


                <div class="card-header bg-info">
                    <h4 class="mb-0 text-white">@ViewBag.Title </h4><a class="mb-0 text-white" style="margin-top:10px !important"> <strong> (@ViewBag.ChitSchemeName) </strong></a>
                </div>

                <div class="card-body">
                    <div id="mytab">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" id="General">
                                <a class="nav-link d-flex active tab" data-bs-toggle="tab" href="#home2" role="tab" aria-selected="true">
                                    <span>
                                        <i class="fa fa-tree"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">General</span>
                                </a>
                            </li>
                            <li class="nav-item" id="AddressDetails">
                                <a class="nav-link d-flex tab1" data-bs-toggle="tab" href="#profile2" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-shipping-fast"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">
                                        Scheme Pattern
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item" id="YardDetails">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#messages2" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-users"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Collection Pattern</span>
                                </a>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane active" id="home2" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <br />
                                        <form action="@Url.Content("~/ChitSchemeManagement/Savedata")" method="post" data-flag="0" class="needs-validation ChitSchemeManagementform" id="ChitSchemeManagementform" name="ChitSchemeManagementform" novalidate onsubmit="return ValidateMyform(this,event);">
                                            <div class="row">
                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="ChitSchemeID">Id</label>
                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="text" id="ChitSchemeID" name="ChitSchemeID" value="@Model.chitscheme[0].ChitSchemeID" class="form-control ChitSchemeID" />
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="ChitSchemeID" name="ChitSchemeID" value="0" class="form-control ChitSchemeID" />
                                                    }
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="ChitTypeID">Type <span class="text-danger">*</span></label>

                                                    @Html.DropDownList("ChitTypeID", null, "Please select Type", new { @class = "form-control select2 custom-select  ChitTypeID", @data_val = "true", @required = "required", @id = "ChitTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Type !!
                                                    </div>

                                                </div>


                                                <div class="col-md-3 mb-3">
                                                    <label for="ChitSchemeCode">Scheme Code <span class="text-danger">*</span></label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="text" id="ChitSchemeCode" name="ChitSchemeCode" value="@Model.chitscheme[0].ChitSchemeCode" class="form-control ChitSchemeCode" required placeholder="Scheme Code" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Code !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="ChitSchemeCode" name="ChitSchemeCode" class="form-control ChitSchemeCode" required placeholder="Scheme Code" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Code !!
                                                        </div>
                                                    }
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="ChitSchemeName">Scheme Name<span class="text-danger">*</span></label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="text" id="ChitSchemeName" name="ChitSchemeName" value="@Model.chitscheme[0].ChitSchemeName" class="form-control ChitSchemeName" required placeholder="Scheme Name" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Name !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="ChitSchemeName" name="ChitSchemeName" class="form-control ChitSchemeName" required placeholder="Scheme Name" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Name !!
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="ChitValue">Value (₹)<span class="text-danger">*</span></label>

                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="ChitValue" name="ChitValue" value="@Model.chitscheme[0].ChitValue" class="form-control ChitValue" required placeholder="Value" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Value !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="ChitValue" name="ChitValue" class="form-control ChitValue" required placeholder="Value" maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Value !!
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
