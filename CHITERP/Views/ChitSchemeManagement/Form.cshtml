                                                    @if (Model.chitscheme.Count > 0)
                                                    {
                                                        <input type="number" id="ForemanCommision" name="ForemanCommision" value="@Model.chitscheme[0].ForemanCommision" class="form-control ForemanCommision" placeholder="Foreman Com" maxlength="50" tabindex="2" />

                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="ForemanCommision" name="ForemanCommision" class="form-control ForemanCommision" placeholder="Foreman Com" maxlength="50" tabindex="2" />

                                                    }
                                                </div>
                                            </div>
                                            <div class="row">

                                                <div class="col-md-2 mb-2">
