        function CalcDiscountAmt(obj) {
            row = obj.parentNode.parentNode.rowIndex;
            row = row - 1;
            // alert("row" + row);
            var $tableBody = $('#SMTDETAIL').find("tbody"),
            $trCur = $tableBody.find("tr:eq(" + row + ")");

            var chitval = $(".ChitValue").val();
            var subsval = $(".SubscriptionAmount").val();
            $trCur.find(".DtlSubsAmt").val(subsval);

            var discperc = $trCur.find(".DiscountPercentage").val();
            //alert(chitval);
            //alert(discperc);
            var discamt = eval(chitval * discperc / 100).toFixed(2);
            var przamt = eval(chitval - discamt).toFixed(2);
            $trCur.find(".DiscountAmount").val(discamt);
            $trCur.find(".DtlPrzAmt").val(przamt);


        }
        function CalcDividentAmt(obj) {
            row = obj.parentNode.parentNode.rowIndex;
            row = row - 1;
            // alert("row" + row);
            var $tableBody = $('#SMTDETAIL').find("tbody"),
            $trCur = $tableBody.find("tr:eq(" + row + ")");

            var chitval = $(".ChitValue").val();
            var divperc = $trCur.find(".DividentPercentage").val();
            //alert(chitval);
            //alert(divperc);
            var divamt = eval(chitval * divperc / 100).toFixed(2);
            $trCur.find(".DividentAmount").val(divamt);
            var subsval = $trCur.find(".DtlSubsAmt").val();
            var dueamt = eval(subsval - divamt).toFixed(2);
            $trCur.find(".DtlDueAmt").val(dueamt);
        }

