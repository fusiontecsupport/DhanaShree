        function SPCalc() {
            var trow = 0;
            var $tableBody = $('#SMTDETAIL').find("tbody")
            var chitval = $(".ChitValue").val();
            var subsval = $(".SubscriptionAmount").val();
            //alert(chitval);
            //alert(subsval);
            $('.SMTDETAIL_BODY tr').each(function () {
                var $crow = $tableBody.find("tr:eq(" + trow + ")");
                //alert($crow.find("#DtlSubsAmt").val());
                $crow.find("#DtlSubsAmt").val(subsval);
                var divamt = $crow.find("#DividentAmount").val();
                var discamt = $crow.find("#DiscountAmount").val();
                var przamt = eval(chitval - discamt).toFixed(2);
                var dueamt = eval(subsval - divamt).toFixed(2);
                $crow.find("#DtlDueAmt").val(dueamt);
                $crow.find("#DtlPrzAmt").val(przamt);
                trow++;
            });

        }

        function ValidateMyform(form, event) {
            $(".preloader").show();
            flag = true;
            i = 0;
            var frmflag = $(form).attr('data-flag');
            //alert(frmflag);
            var form = document.getElementById('ChitSchemeManagementform');
            var inputs = form.getElementsByTagName('input');
            var forms = document.getElementsByClassName('needs-validation');

            if (form.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
                $(".preloader").hide();
                flag = false;
            }
            else {
                form.classList.add('was-validated'); flag = true;
            }
            //alert(flag);
            if (flag) {
                if (frmflag == 0) {
                    event.preventDefault(); //to prevent submitting

                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        //position: "Center",
                    }).then((result) => {
                        if (result.value) {
                            flag = true;
                            var ActionName = "SaveData";
                            var controllername = "ChitSchemeManagement";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#ChitSchemeManagementform').serialize();
                            submitFormData(ActionName, controllername, pagetitle, formData);

                        }
                        else if (result.isDenied) {
                            Swal.fire('Changes are not saved', '', 'info')
                            flag = false;
                            $(".preloader").hide();
                            return false;
                        }
                    });
                }
            }
            else {
                $(".preloader").hide();
                return false;
            }
            $(".preloader").hide();
        }

        function Chk(obj) {
            test = $(obj).prop("checked");

            if (test == true) {
                $(obj).prop('checked', true);
                $(".boolReGen").val("1");
            }
            else {
                $(obj).prop('checked', false);
                $(".boolReGen").val("0");
            }
