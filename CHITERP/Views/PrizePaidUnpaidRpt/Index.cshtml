@{
    ViewBag.Title = "Chit Prize Paid / Unpaid Clients Summary - Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-12">
                    <div class="card-header border-bottom" style="background-color:white;">
                        <div class="d-flex no-block align-items-center mb-0">
                            <h3 class="card-title text-dark-primary"><i class="fa fa-dashboard fa-fw"></i>@ViewBag.Title</h3>
                        </div>
                    </div>
                    <br />
                    <div class="col-lg-12" style="margin-top:10px">
                        <form target="_blank" action="@Url.Action("PrizePaidUnpaidClientsXLRpt", "PrizePaidUnpaidRpt")/" method="post" accept-charset="utf-8" id="FinExcelRptForm" data-ng-controller="myController" name="FinExcelRptForm">
                            <div class="row">
                                <div class="col-md-2 mb-2 hide">
                                    <label for="from">Product</label>

                                    @Html.DropDownList("ProductType", null, "-- Select --", new { @class = "form-control select2 custom-select  ProductType", @data_val = "true", @id = "ProductType", @style = "width:50%;" })
                                    <div class="invalid-feedback">
                                        Please Select Product !!
                                    </div>
                                </div>


                                <div class="col-md-2 mb-2">
                                    <label for="from">Prize Paid Status</label>

                                    @Html.DropDownList("PdSts", null, "-- Select --", new { @class = "form-control select2 custom-select  PdSts", @data_val = "true", @id = "PdSts", @style = "width:50%;" })
                                    <div class="invalid-feedback">
                                        Please Select Paid Status !!
                                    </div>
                                </div>


                                <div class="col-md-2 mb-2">
                                    <br />
                                    <input type="submit" name="submit" value="Download Excel Report" class="btn btn-info btn-sm" />
                                </div>
                            </div>
                        </form>

                    </div>
                    <br />

                </div>
            </div>
        </div>


    </div>

</div>


@section Scripts {


    <script type="text/javascript">
    $(document).ready(function () {

        });



    </script>

}