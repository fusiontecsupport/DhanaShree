@model CHITERP.Models.ApplicationGroups


@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">

            <div class="card">
                <div class="card-body">
                    <h3 class="card-title mb-3 pb-3 border-bottom">Create</h3>
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true)

                        <div class="row">

                            <div class="col-md-3 mb-3">
                                @Html.LabelFor(model => model.Name, new { @class = "control-label col-md-2" })
                                @Html.EditorFor(model => model.Name, new { @class = "form-control Name", @id = "Name" })
                                @Html.ValidationMessageFor(model => model.Name)
                            </div>

                            <div class="col-md-6 mb-6">
                                @Html.LabelFor(model => model.Description, new { @class = "control-label col-md-2" })
                                @Html.EditorFor(model => model.Description, new { @class = "form-control Description", @id = "Description" })
                                @Html.ValidationMessageFor(model => model.Description)
                            </div>



                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-6">

                                <label>Select Group Roles</label>
                                @foreach (var item in (SelectList)ViewBag.RolesList)
                                {
                                    <div>
                                        <input type="checkbox" name="SelectedRoles" value="@item.Text" class="checkbox-inline" />
                                        @Html.Label(item.Text, new { @class = "control-label" })
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-md-flex align-items-center mt-3">

                                <a href="@Url.Action("Index", "Groups")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Back to List</a>

                                <div class="ms-auto mt-3 mt-md-1 pull-right">
                                    <input type="submit" value="Create" class="btn btn-info font-weight-medium rounded-pill px-4" />

                                </div>
                            </div>
                        </div>
                    }
                </div>
                <!---->
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}


