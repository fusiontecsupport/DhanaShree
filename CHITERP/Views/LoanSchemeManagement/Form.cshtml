@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {

            if ($('#LoanSchemeID').val() == "") {
                $('#LoanSchemeID').val("0");
            }

            //if (($('#LoanSchemeID').val() == "0" || $('#LoanSchemeID').val() == "")) {
            //    //$("#mytab ul li a.tab1").addClass("disabled");
            //    //$("#mytab ul li a.tab2").addClass("disabled");
            //    $("#mytab ul li a").addClass("disabled");
            //}
            //else {
            //    $("#mytab ul li a").removeClass("disabled");
            //}

            var smtblrowcount = $('#SMTDETAIL tbody tr').length;
            $("#SMTDETAILIDX").val(smtblrowcount);

            $("#smadd_detail").click(function () {
                if ($("#SMTDETAILIDX").val() != 0) {

                    var $tableBody = $('#SMTDETAIL').find("tbody"),
                        $trLast = $tableBody.find("tr:last");

                    $trNew = $trLast.clone();
                    $trLast.after($trNew);

                    $trNew.find("span").remove();

                    $trNew.find("#LoanVariableRangeID").val("0");
                    $trNew.find("#LoanSecuredTypeId").val("");
                    $trNew.find("#DisbursementModeTypeID").val("");
                    $trNew.find("#VariableTypeId").val("");
                    $trNew.find("#TopLimit").val("0.00");
                    $trNew.find("#BottomLimit").val("0.00");
                    $trNew.find("#TermTypeID").val("");

                    trow = 1;

