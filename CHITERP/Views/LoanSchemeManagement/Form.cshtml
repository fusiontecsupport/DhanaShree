                                                                        </td>

                                                                        <td class=" col-md-1">

                                                                            <a class="btn btn-danger btn-sm" id="emdel_detail"> <i class="fa fa-trash" style="color:white"></i></a>

                                                                        </td>

                                                                    </tr>

                                                                }
                                                            }
                                                            else
                                                            {
                                                                <tr class="item-row">

                                                                    <td class="col-md-2">
                                                                        <input type="text" id="LoanFormulaID" class="LoanFormulaID hide" name="LoanFormulaID" value="0" />
                                                                        @Html.DropDownList("LoanTransactionTypeID", null, "-- Select --", new { @class = "form-control custom-select select2 LoanTransactionTypeID", @id = "LoanTransactionTypeID", @name = "LoanTransactionTypeID" })
                                                                    </td>

                                                                    <td class="col-md-3">
                                                                        @Html.DropDownList("InterestDeductionTypeID", null, "-- Select --", new { @class = "form-control custom-select select2 InterestDeductionTypeID", @id = "InterestDeductionTypeID", @name = "InterestDeductionTypeID" })                                                                       
