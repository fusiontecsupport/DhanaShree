                                                                            <input id="TopLimit" type="number" value="@details.TopLimit" name="TopLimit" class="form-control TopLimit" />
                                                                        </td>
                                                                        <td class="col-md-3">
                                                                            @Html.DropDownListFor(model => Model.loanvariablerangs[0].TermTypeID, new SelectList(ViewBag.TermTypeID, "value", "text", @details.TermTypeID), "-- Select --", new { @class = "form-control custom-select select2 TermTypeID", @id = "TermTypeID", @name = "TermTypeID" })
                                                                        </td>

                                                                        <td class=" col-md-1">
                                                                            <a class="btn btn-danger btn-sm" id="smdel_detail"> <i class="fa fa-trash" style="color:white"></i></a>
                                                                        </td>

                                                                    </tr>

                                                                }
                                                            }
                                                            else
                                                            {
                                                                <tr class="item-row">

                                                                    <td class="col-md-1">
                                                                        <input type="text" id="LoanVariableRangeID" class="LoanVariableRangeID hide" name="LoanVariableRangeID" value="0" />
                                                                        @Html.DropDownList("LoanSecuredTypeId", null, "-- Select --", new { @class = "form-control custom-select select2 LoanSecuredTypeId", @id = "LoanSecuredTypeId", @name = "LoanSecuredTypeId" })
                                                                    </td>

                                                                    <td class="col-md-3">
                                                                        @Html.DropDownList("DisbursementModeTypeID", null, "-- Select --", new { @class = "form-control custom-select select2 DisbursementModeTypeID", @id = "DisbursementModeTypeID", @name = "DisbursementModeTypeID" })
                                                                    </td>

                                                                    <td class="col-md-3">
                                                                        @Html.DropDownList("VariableTypeId", null, "-- Select --", new { @class = "form-control custom-select select2 VariableTypeId", @id = "VariableTypeId", @name = "VariableTypeId" })
                                                                    </td>

                                                                    <td class="col-md-3">
                                                                        <input id="BottomLimit" type="number" value="0" name="BottomLimit" class="form-control BottomLimit" />
                                                                    </td>

                                                                    <td class="col-md-3">
                                                                        <input id="TopLimit" type="number" value="0" name="TopLimit" class="form-control TopLimit" />
                                                                    </td>

                                                                    <td class="col-md-3">
                                                                        @Html.DropDownList("TermTypeID", null, "-- Select --", new { @class = "form-control custom-select select2 TermTypeID", @id = "TermTypeID", @name = "TermTypeID" })
                                                                    </td>

                                                                    <td class=" col-md-1">
                                                                        <a class="btn btn-danger btn-sm" id="smdel_detail"> <i class="fa fa-trash" style="color:white"></i></a>
                                                                    </td>

                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>

                                                <div class="col-12">
                                                    <div class="d-md-flex align-items-center mt-3">

                                                        <a href="@Url.Action("Form", "LoanSchemeManagement")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>

                                                        <div class="ms-auto mt-3 mt-md-1 pull-right">

                                                            <button id="btnsmsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane p-3" id="messages2" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <div class="card-body">
                                            <form action="@Url.Content("~/LoanSchemeManagement/SaveLFData")" method="post" data-flag="0" class="needs-validation LoanFormulaform" id="LoanFormulaform" name="LoanFormulaform" novalidate onsubmit="return ValidateEmployeeform(this,event);">
                                                <div class="row">
                                                    <div class="col-lg-3 hide">
                                                        <div class="form-group">
                                                            <label>primary</label>
                                                            <input class="form-control" id="LoanSchemeID" value="@ViewBag.LoanSchemeID" name="LoanSchemeID" />
                                                        </div>
                                                    </div>
                                                    <input type="text" id="EMTDETAILIDX" value="0" name="EMTDETAILIDX" class="EMTDETAILIDX hide" />
