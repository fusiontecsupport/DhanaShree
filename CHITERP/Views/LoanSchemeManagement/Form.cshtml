                                                                        @Html.DropDownList("RepaymentIntervalTypeID",null,"-- Select --", new { @class = "form-control custom-select select2 RepaymentIntervalTypeID", @id = "RepaymentIntervalTypeID", @name = "RepaymentIntervalTypeID" })
                                                                    </td>

