@using CHITERP.Models;
@model CHITERP.Models.LoanSchemeList

@{
    ViewBag.Title = "Loan Scheme";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .spacer5 {
        height: 15px;
    }
    /*   body {
        font-family: Arial !important;
    }*/
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">


                <div class="card-header bg-info">
                    <h4 class="mb-0 text-white">@ViewBag.Title </h4><a class="mb-0 text-white" style="margin-top:10px !important"> <strong> (@ViewBag.LoanSchemeName) </strong></a>
                </div>

                <div class="card-body">
                    <div id="mytab">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" id="General">
                                <a class="nav-link d-flex active tab" data-bs-toggle="tab" href="#home2" role="tab" aria-selected="true">
                                    <span>
                                        <i class="fa fa-tree"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">
                                        Scheme Parameters
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item hide" id="VariableRangeDetails">
                                <a class="nav-link d-flex tab1" data-bs-toggle="tab" href="#profile2" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-shipping-fast"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">
                                        Variable Range
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item hide" id="FormulaDetails">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#messages2" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-users"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Formula</span>
                                </a>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane active" id="home2" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <br />
                                        <form action="@Url.Content("~/LoanSchemeManagement/Savedata")" method="post" data-flag="0" class="needs-validation LoanSchemeform" id="LoanSchemeform" name="LoanSchemeform" novalidate onsubmit="return ValidateMyform(this,event);">
                                            <div class="row">
                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="ChitSchemeID">Id</label>
                                                    @if (Model.loanschemes.Count > 0)
                                                    {
                                                        <input type="text" id="LoanSchemeID" name="LoanSchemeID" value="@Model.loanschemes[0].LoanSchemeID" class="form-control LoanSchemeID" />
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="LoanSchemeID" name="LoanSchemeID" value="0" class="form-control LoanSchemeID" />
                                                    }
                                                </div>

                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="AmountCodeID">Amount Code <span class="text-danger">*</span></label>

                                                    @Html.DropDownList("AmountCodeID", null, "Please select Amount Code", new { @class = "form-control select2 custom-select  AmountCodeID", @data_val = "true", @id = "AmountCodeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Amount Code !!
                                                    </div>

                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="SchemeCode">Scheme Code <span class="text-danger">*</span></label>

                                                    @if (Model.loanschemes.Count > 0)
                                                    {
                                                        <input type="text" id="SchemeCode" name="SchemeCode" value="@Model.loanschemes[0].SchemeCode" class="form-control SchemeCode" required maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Code !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="SchemeCode" name="SchemeCode" class="form-control SchemeCode" required maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Code !!
                                                        </div>
                                                    }
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="SchemeName">Scheme Name<span class="text-danger">*</span></label>
                                                    @if (Model.loanschemes.Count > 0)
                                                    {
                                                        <input type="text" id="SchemeName" name="SchemeName" value="@Model.loanschemes[0].SchemeName" class="form-control SchemeName" required maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Name !!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="SchemeName" name="SchemeName" class="form-control SchemeName" required maxlength="50" tabindex="2" />
                                                        <div class="invalid-feedback">
                                                            Please Enter Scheme Name !!
                                                        </div>
                                                    }
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="BookVerificationIntervalTypeID">Book Verification <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("BookVerificationIntervalTypeID", null, "Please select", new { @class = "form-control select2 custom-select  BookVerificationIntervalTypeID", @data_val = "true", @required = "required", @id = "BookVerificationIntervalTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Book Verification !!
                                                    </div>

                                                </div>
                                                
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-2 mb-2">
                                                    <label for="TenureBased">Tenure Based</label>
                                                    @if (Model.loanschemes.Count > 0)
                                                    {
                                                        if (@Model.loanschemes[0].TenureBased == true)
                                                        {
                                                            <input type="checkbox" name="TenureBased" value="@Model.loanschemes[0].TenureBased" id="TenureBased" onchange="ChkTnr(this)" checked="checked" tabindex="2" />
                                                            <input type="text" value="1" id="boolTenureBased" class="boolTenureBased hide" name="boolTenureBased" />
                                                        }
                                                        else
                                                        {
                                                            <input type="checkbox" name="TenureBased" value="@Model.loanschemes[0].TenureBased" id="TenureBased" onchange="ChkTnr(this)" tabindex="2" />
                                                            <input type="text" value="0" id="boolTenureBased" class="boolTenureBased hide" name="boolTenureBased" />
                                                        }
                                                        
                                                    }
                                                    else
                                                    {
                                                        <input type="checkbox" name="TenureBased" value="1" id="TenureBased" tabindex="2" />
                                                        <input type="text" value="1" id="boolTenureBased" class="boolTenureBased hide" name="boolTenureBased" />
                                                    }


                                                </div>

                                                <div class="col-md-2 mb-2 hide">

                                                    <label for="EMIBased">EMI Based</label>
                                                    @if (Model.loanschemes.Count > 0)
                                                    {
                                                        if (Model.loanschemes[0].EMIBased == true)
                                                        {
                                                            <input type="checkbox" name="EMIBased" value="@Model.loanschemes[0].EMIBased" id="EMIBased" checked="checked" onchange="ChkEmi(this)" tabindex="2" />
                                                            <input type="text" value="1" id="boolEMIBased" class="boolEMIBased hide" name="boolEMIBased" />
                                                        }
                                                        else
                                                        {
                                                            <input type="checkbox" name="EMIBased" value="@Model.loanschemes[0].EMIBased" id="EMIBased" onchange="ChkEmi(this)" tabindex="2" />
                                                            <input type="text" value="0" id="boolEMIBased" class="boolEMIBased hide" name="boolEMIBased" />
                                                        }

                                                    }
                                                    else
                                                    {
                                                        <input type="checkbox" name="EMIBased" value="0" id="EMIBased" tabindex="2" />
                                                        <input type="text" value="0" id="boolEMIBased" class="boolEMIBased hide" name="boolEMIBased" />
                                                    }

                                                </div>

                                                <div class="col-md-2">
                                                    <label for="StatusTypeID" class="col-md-5 control-label">Status<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("StatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  StatusTypeID", @data_val = "true", @required = "required", @id = "StatusTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Status !!
                                                    </div>
                                                </div>

                                            </div>

                                            <div class="col-12">
                                                <div class="d-md-flex align-items-center mt-3">

                                                    <a href="@Url.Action("Index", "LoanSchemeManagement")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>

                                                    <div class="ms-auto mt-3 mt-md-1 pull-right">
                                                        <button id="btnsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane p-3" id="profile2" role="tabpanel">
