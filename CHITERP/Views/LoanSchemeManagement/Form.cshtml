        function ChkTnr(obj) {
            test = $(obj).prop("checked");
            //alert(test);
            $(obj).prop("checked", false);
            $(".boolTenureBased").val("0");

            if (test == true) {
                $(obj).prop("checked", true);
                $(".boolTenureBased").val("1");

            }
            else {
                $(obj).prop("checked", false);
                $(".boolTenureBased").val("0");

            }

