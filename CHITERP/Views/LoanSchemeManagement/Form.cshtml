                                                                            <input type="text" id="LoanFormulaID" class="LoanFormulaID hide" name="LoanFormulaID" value="@details.LoanFormulaID" />
                                                                            @Html.DropDownListFor(model => Model.loanformulas[0].LoanTransactionTypeID, new SelectList(ViewBag.LoanTransactionTypeID, "value", "text", @details.LoanTransactionTypeID), "-- Select --", new { @class = "form-control custom-select select2 LoanTransactionTypeID", @id = "LoanTransactionTypeID", @name = "LoanTransactionTypeID" })


                                                                        </td>

                                                                        <td class="col-md-3">
                                                                            @Html.DropDownListFor(model => Model.loanformulas[0].InterestDeductionTypeID, new SelectList(ViewBag.InterestDeductionTypeID, "value", "text", @details.InterestDeductionTypeID), "-- Select --", new { @class = "form-control custom-select select2 InterestDeductionTypeID", @id = "InterestDeductionTypeID", @name = "InterestDeductionTypeID" })
                                                                        </td>

                                                                        <td class="col-md-3">
                                                                            @Html.DropDownListFor(model => Model.loanformulas[0].RepaymentIntervalTypeID, new SelectList(ViewBag.RepaymentIntervalTypeID, "value", "text", @details.RepaymentIntervalTypeID), "-- Select --", new { @class = "form-control custom-select select2 RepaymentIntervalTypeID", @id = "RepaymentIntervalTypeID", @name = "RepaymentIntervalTypeID" })
                                                                        </td>

                                                                        <td class="col-md-3">
