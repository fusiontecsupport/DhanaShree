@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {

            if ($('#LoanRequestID').val() == "") {
                $('#LoanRequestID').val("0");
            }
            else {
                ClientNameChange();
                CalcInterest();
            }
            

            var reqsts = $('#ReqStatusTypeID option:selected').val();
            //alert(reqsts);
            if (reqsts < 898) {
                $('#CollectionType').removeAttr('required', 'required');
                $('#RepaymentIntervalTypeID').removeAttr('required', 'required');
                $('#BookPickupDay').removeAttr('required', 'required');                
                $('#RouteID').removeAttr('required', 'required');
                //$('#StatusTypeID').removeAttr('required', 'required');

            }
            else {
                $('#CollectionType').attr('required', 'required');
                $('#RepaymentIntervalTypeID').attr('required', 'required');
                $('#BookPickupDay').attr('required', 'required');                
                //$('#RouteID').attr('required', 'required');
                //$('#StatusTypeID').attr('required', 'required');

            }
        });

        function CalcInterest() {

            var princ = $(".Principal").val();
            var lnamt = $(".LoanAmount").val();
            var term = $(".Term").val();
            var intrt = 0;
            if (eval(princ) > 0 && eval(lnamt) > 0, eval(term) > 0) {
                intrt = eval(princ - lnamt) / eval(term);
                if (intrt > 0)
                    intrt = (eval(intrt) / eval(princ)).toFixed(2);
                else
                    intrt = 0;
            }
            $(".InterestRate").val(intrt*100);
        }
        function ClientNameChange() {

            var clientid = $(".FPersonID").val();
            $(".PersonID").val(clientid);
            //alert($(".PersonID").val());
            $("#IntroducedBy").val("");

            if (clientid != null && clientid != "0" && clientid != "" ) {
                  //alert(clientid);
            $.ajax({
                type: 'post',
                url: '@Url.Action("Get_Introduced_by_Name", "ChitSubscriptionManagement")/' + clientid , // we are calling json method
                dataType: 'json',
                success: function (data) {
                    if (data.length > 0) {
                        //console.log(data);
                        $("#IntroducedBy").val(data[0].CLIENTNAME);
                    }

                },
                complete: function () {
                },
                error: function (ex) {
                    //alert('Failed to data ' + ex);
                }
            });
            }

        }

        function ValidateMyform(form, event) {
            flag = true;
            i = 0;
            var frmflag = $(form).attr('data-flag');
            //alert(frmflag);
            var clientid = $(".FPersonID").val();
            if (clientid == "" || clientid == "0") {
                flag = false;
                alert('Please Select Client');
                $(".FPersonID").focus();
                return;
            }
            var form = document.getElementById('LoanSubscriptionManagementform');
            var inputs = form.getElementsByTagName('input');
            var forms = document.getElementsByClassName('needs-validation');

            if (form.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
                flag = false;
            }
            else {
                form.classList.add('was-validated'); flag = true;
            }
            //alert(flag);
            if (flag) {
                if (frmflag == 0) {
                    event.preventDefault(); //to prevent submitting


                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        position: "Center",
                    }).then((result) => {
                        if (result.value) {
                            flag = true;
                            var ActionName = "SaveData";
                            var controllername = "LoanSubscription";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#LoanSubscriptionManagementform').serialize();
                            submitFormData(ActionName, controllername, pagetitle, formData);

                        }
                        else if (result.isDenied) {
                            Swal.fire('Changes are not saved', '', 'info')
                            flag = false;
                            return false;
                        }
                    });
                }
            }
            else {
                return false;
            }
        }

    </script>

}


