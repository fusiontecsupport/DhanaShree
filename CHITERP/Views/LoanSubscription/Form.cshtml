@using CHITERP.Models;
@using CHITERP.Data;
@model CHITERP.Models.LoanTranRS

@{
    ViewBag.Title = "Loan Subscription";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">

                <div class="card-header bg-info">
                    <h4 class="mb-0 text-white">@ViewBag.Title </h4><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                </div>

                <div class="card-body">

                    <div class="row">
                        <div class="row col-md-12">
                            <div class="col-md-3 mb-3">

                                <label for="LoanSubscriptionId">Loan Subscription Code</label>


                                @if (Model != null)
                                {
                                <input class="form-control LoanSubscriptionCode" id="LoanSubscriptionCode" readonly value="@Model.loansubs[0].LoanSubscriptionCode" name="LoanSubscriptionCode" />
                                }
                                else
                                {
                                <input class="form-control LoanSubscriptionCode" id="LoanSubscriptionCode" readonly value="0" name="LoanSubscriptionCode" />
                                }

                            </div>
                            <div class="col-md-5 mb-5">
                                <label for="FPersonID">Organization/Person</label>

                                @Html.DropDownList("FPersonID", null, "Please Select Organization/Person", new
                                {
                                    @class = "form-control select2 custom-select  FPersonID",
                                    @data_val = "true",
                                    @required = "required",
                                    @id = "FPersonID",
                                    @onchange = "ClientNameChange();"
                                })
                                <div class="invalid-feedback">
                                    Please Select Organization/Person !!
                                </div>
                            </div>
                            <div class="col-md-3 mb-3 hide">

                                <label for="ClientType">Organization/Person</label>
                                @Html.DropDownList("ClientType", null, "Please select Type", new { @class = "form-control select2 custom-select  ClientType", @data_val = "true", @required = "required", @id = "ClientType", @style = "width:50%;" })
                                <div class="invalid-feedback">
                                    Please Select Client Type!!
                                </div>

                            </div>
                            <div class="col-md-4 mb-4">

                                <label for="IntroducedBy">Introduced By	</label>

                                <input type="text" readonly id="IntroducedBy" class="form-control" name="IntroducedBy" />

                            </div>
                        </div>
                    </div>

                    <div id="mytab">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" id="LRequest">
                                <a class="nav-link d-flex active tab" data-bs-toggle="tab" href="#LoanRequest" role="tab" aria-selected="true">
                                    <span>
                                        <i class="fa fa-rocket"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Planner</span>
                                </a>
                            </li>

                            <li class="nav-item " id="LSubscription">
                                <a class="nav-link d-flex tab1" data-bs-toggle="tab" href="#LoanPaymentSchedule" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-book"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">
                                        Loan Payment Schedule
                                    </span>
                                </a>
                            </li>

                            <li class="nav-item hide" id="LAddress">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#LoanAddress" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-phone"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Address</span>
                                </a>
                            </li>

                            <li class="nav-item  hide" id="LAllocation">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#LoanAllocation" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-hand-holding-usd"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Loan Allocation</span>
                                </a>
                            </li>
                            <li class="nav-item" id="LQRCode">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#LoanQRCode" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-qrcode"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">QRCode</span>
                                </a>
                            </li>
                            <li class="nav-item" id="LClosure">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#LoanClosure" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-piggy-bank"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Closure</span>
                                </a>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane active" id="LoanRequest" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <br />
                                        <form action="@Url.Content("~/LoanSubscription/Savedata")" method="post" data-flag="0" class="needs-validation LoanSubscriptionManagementform" id="LoanSubscriptionManagementform" name="LoanSubscriptionManagementform" novalidate onsubmit="return ValidateMyform(this,event);">
                                            <div class="card-header bg-success">
                                                <h5 class="mb-0 text-white">Loan Request Plan </h5><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="SubscriptionID">Id</label>
                                                    @if (Model != null)
                                                    {
                                                    <input class="form-control LoanSubscriptionId" id="LoanSubscriptionId" readonly value="@Model.loansubs[0].LoanSubscriptionID" name="LoanSubscriptionID" />
                                                    <input type="text" id="LoanRequestID" name="LoanRequestID" value="@Model.loanrequests[0].LoanRequestID" class="form-control LoanRequestID" />
                                                    <input type="text" id="PersonID" name="PersonID" value="@Model.loanrequests[0].PersonID" class="form-control PersonID" />
                                                    }
                                                    else
                                                    {
                                                    <input class="form-control LoanSubscriptionId" id="LoanSubscriptionId" readonly value="0" name="LoanSubscriptionID" />
                                                    <input type="text" id="LoanRequestID" name="LoanRequestID" value="0" class="form-control LoanRequestID" />
                                                    <input type="text" id="PersonID" name="PersonID" value="" class="form-control PersonID" />
                                                    }
                                                </div>


                                                <div class="col-md-3 mb-3">
                                                    <label for="LoanSchemeID">Loan Scheme<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("LoanSchemeID", null, "-- Select --", new { @class = "form-control select2 custom-select  LoanSchemeID", @data_val = "true", @required = "required", @id = "LoanSchemeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Loan Scheme !!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="LoanSecuredTypeId">Secured<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("LoanSecuredTypeId", null, "-- Select --", new { @class = "form-control select2 custom-select  LoanSecuredTypeId", @data_val = "true", @required = "required", @id = "LoanSecuredTypeId", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Secured !!
                                                    </div>

                                                </div>
                                                <div class="col-md-3 mb-3">
                                                    <label>Requested On<span class="text-danger">*</span></label>

                                                    @if (Model != null)
                                                    {
                                                    <input id="RequestedOn" type="date" value="@String.Format("{0:yyyy-MM-dd}",Model.loanrequests[0].RequestedOn)" name="RequestedOn" required class="form-control RequestedOn" />
                                                    }
                                                    else
                                                    {
                                                    <input id="RequestedOn" type="date" value="" name="RequestedOn" class="form-control RequestedOn" required />
                                                    }


                                                    <div class="invalid-feedback">
                                                        Please Select Requested On !!
                                                    </div>

                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="Principal">Loan Requested Amount<span class="text-danger">*</span></label>

                                                    @if (Model != null)
                                                    {
                                                        <input type="number" id="Principal" name="Principal" min="0.00" step="0.01" value="@Model.loanrequests[0].Principal" class="form-control Principal" required maxlength="18" onchange="CalcInterest();" tabindex="2" />
                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="Principal" name="Principal" min="0.00" step="0.01" class="form-control Principal" required maxlength="18" tabindex="2" onchange="CalcInterest();" />
                                                    }
                                                    <div class="invalid-feedback">
                                                        Please Enter Loan Requested Amount!!
                                                    </div>

                                                </div>
                                            </div>
                                            <br />
                                            <div class="card-header bg-success">
                                                <h5 class="mb-0 text-white">Loan Disbursement Information </h5><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                                            </div>
                                            <br />


                                            <div class="row col-md-12">
                                                <div class="col-md-2 mb-2">
                                                    <label for="DisbursementModeTypeID">Disbursement Mode<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("DisbursementModeTypeID", null, "-- Select --", new { @class = "form-control select2 custom-select  DisbursementModeTypeID", @data_val = "true", @required = "required", @id = "DisbursementModeTypeID", @style = "width:50%;"})
                                                    <div class="invalid-feedback">
                                                        Please Select Disbursement Mode !!
                                                    </div>
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="RepaymentModeTypeID">Repayment Mode<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("RepaymentModeTypeID", null, "-- Select --", new { @class = "form-control select2 custom-select  RepaymentModeTypeID", @data_val = "true", @required = "required", @id = "RepaymentModeTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Repayment Mode !!
                                                    </div>
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="LoanAmount">Disbursement Amount<span class="text-danger">*</span></label>

                                                    @if (Model != null)
                                                    {
                                                    <input type="number" id="LoanAmount" name="LoanAmount" min="0.00" step="0.01" value="@Model.loanrequests[0].LoanAmount" class="form-control LoanAmount" required onchange="CalcInterest();" maxlength="18" tabindex="2" />
                                                    <div class="invalid-feedback">
                                                        Please Enter Disbursement Amount   !!
                                                    </div>
                                                    }
                                                    else
                                                    {
                                                    <input type="number" id="LoanAmount" name="LoanAmount" min="0.00" step="0.01" class="form-control LoanAmount" required maxlength="18" onchange="CalcInterest();" tabindex="2" />
                                                    <div class="invalid-feedback">
                                                        Please Enter Disbursement Amount   !!
                                                    </div>
                                                    }
                                                </div>
                                                <div class="col-md-4 mb-4">
                                                    <div class="mb-3 row">
                                                        <label class="col-sm-2 text-end control-label col-form-label">Term	</label>
                                                        <br />
                                                        <div class="col-sm-4">
                                                            @if (Model != null)
                                                            {
                                                                <input type="number" id="Term" min="0" name="Term" value="@Model.loanrequests[0].Term" required class="form-control Term" maxlength="10" onchange="CalcInterest();" tabindex="2" />
                                                            }
                                                            else
                                                            {
                                                                <input type="number" id="Term" min="0" name="Term" class="form-control Term" required maxlength="10" tabindex="2" onchange="CalcInterest();" />
                                                            }
                                                            <div class="invalid-feedback">
                                                                Please Enter Term  !!
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-5">
                                                            @Html.DropDownList("TermTypeID", null, "-- Select --", new { @class = "form-control select2 custom-select  TermTypeID", @data_val = "true", @id = "TermTypeID", @style = "width:50%;", @required = "required" })
                                                            <div class="invalid-feedback">
                                                                Please Enter Term Type !!
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="InterestRate">Interest Rate (%)</label>

                                                    @if (Model != null)
                                                    {
                                                        <input type="number" id="InterestRate" min="0" step="0.01" required name="InterestRate" value="@Model.loanrequests[0].InterestRate" class="form-control InterestRate" maxlength="3" tabindex="2" />
                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="InterestRate" min="0" step="0.01" required name="InterestRate" class="form-control InterestRate" maxlength="3" tabindex="2" />
                                                    }
                                                <div class="invalid-feedback">
                                                    Please Enter Interest Rate % !!
                                                </div>
                                                </div>

                                            </div>
                                            <div class="row col-md-12">
                                                <div class="col-md-2 mb-2">
                                                    <label for="DeductionTypeId">Deduction<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("DeductionTypeId", null, "-- select --", new { @class = "form-control select2 custom-select  DeductionTypeId", @data_val = "true", @required = "required", @id = "DeductionTypeId", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Deduction !!
                                                    </div>

                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label>Disbursement Date<span class="text-danger">*</span></label>
                                                    @if (Model != null)
                                                    {
                                                        <input id="DisbursementDate" type="date" value="@String.Format("{0:yyyy-MM-dd}",Model.loanrequests[0].DisbursementDate)" name="DisbursementDate" required class="form-control DisbursementDate" />

                                                    }
                                                    else
                                                    {
                                                        <input id="DisbursementDate" type="date" value="" name="DisbursementDate" class="form-control DisbursementDate" required />
                                                    }
                                                    <div class="invalid-feedback">
                                                        Please Select Disbursement Date !!
                                                    </div>
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="StatusTypeID">Planner Status<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("ReqStatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  ReqStatusTypeID", @data_val = "true", @required = "required", @id = "ReqStatusTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Status !!
                                                    </div>
                                                </div>

                                                <div class="col-md-4 mb-4">
                                                    <label for="LinkedOfficeID">Linked Office<span class="text-danger">*</span></label>
                                                     @Html.DropDownList("LinkedOfficeID", null, "Please select", new { @class = "form-control select2 custom-select  LinkedOfficeID", @data_val = "true", @required = "required", @id = "LinkedOfficeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Linked Office !!
                                                    </div>
                                                </div>

                                            </div>
                                            <div class="row col-md-12">



                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="LoanCode">Loan Amount Code <span class="text-danger">*</span></label>

                                                    @Html.DropDownList("AmountCodeID", null, "Please select Amount Code", new { @class = "form-control select2 custom-select  AmountCodeID", @data_val = "true", @id = "AmountCodeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Amount Code !!
                                                    </div>

                                                </div>
                                                

                                                <div class="col-md-2 mb-2 hide">
                                                    <label>Agent Commission</label>
                                                    @if (Model != null)
                                                    {
                                                    <input id="AgentCommission" type="number"  min="0.00" step="0.01" value="@Model.loanrequests[0].AgentCommission" name="AgentCommission" class="form-control AgentCommission" />
                                                    }
                                                    else
                                                    {
                                                    <input id="AgentCommission" type="number" min="0.00" step="0.01"  value="" name="AgentCommission" class="form-control AgentCommission" />
                                                    }
                                                </div>

                                                <div class="col-md-2 mb-2 hide">
                                                    <label>Commission Agent</label>
                                                    @Html.DropDownList("CommissionAgentPersonID", null, "-- Select --", new { @class = "form-control select2 custom-select  CommissionAgentPersonID", @data_val = "true", @id = "CommissionAgentPersonID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Commission Agent !!
                                                    </div>
                                                </div>
                                                <div class="col-md-3 mb-3 hide">
                                                    <label>Co Applicants</label>
                                                    @Html.DropDownList("CoApplicants", null, new { @class = "form-control select2 custom-select  CoApplicants", @data_val = "true", @id = "CoApplicants", @style = "width:50%;", @multiple = "multiple" })

                                                </div>
                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="LoanSchemeID">Loan Scheme<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("LoanSubsSchemeID", null, "-- Select --", new { @class = "form-control select2 custom-select  LoanSubsSchemeID", @data_val = "true", @id = "LoanSubsSchemeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Loan Scheme !!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="LoanSecuredTypeId">Secured<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("LoanSubsSecuredTypeId", null, "-- Select --", new { @class = "form-control select2 custom-select  LoanSubsSecuredTypeId", @data_val = "true", @id = "LoanSubsSecuredTypeId", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Secured !!
                                                    </div>

                                                </div>
                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="SubsRepaymentModeTypeID">Repayment Mode<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("SubsRepaymentModeTypeID", null, "-- Select --", new { @class = "form-control select2 custom-select  SubsRepaymentModeTypeID", @data_val = "true", @id = "SubsRepaymentModeTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Repayment Mode !!
                                                    </div>
                                                </div>
                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="SubsLinkedOfficeID">Linked Office<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("SubsLinkedOfficeID", null, "Please select Linked Office", new { @class = "form-control select2 custom-select  SubsLinkedOfficeID", @data_val = "true", @id = "SubsLinkedOfficeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Linked Office !!
                                                    </div>
                                                </div>




                                            </div>

                                            <br />
                                            <div class="card-header bg-success">
                                                <h5 class="mb-0 text-white">Loan Collection Information </h5><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                                            </div>
                                            <div class="row col-md-12">

                                                <div class="col-md-3 mb-3">
                                                    <label for="CollectionType">Collection Type</label>

                                                    @Html.DropDownList("CollectionType", null, "Please select", new { @class = "form-control select2 custom-select  CollectionType", @data_val = "true", @required = "required", @id = "CollectionType", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Collection Type !!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="RepaymentIntervalTypeID">Interval</label>

                                                    @Html.DropDownList("RepaymentIntervalTypeID", null, "Please select", new { @class = "form-control select2 custom-select  RepaymentIntervalTypeID", @data_val = "true", @required = "required", @id = "RepaymentIntervalTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Interval !!
                                                    </div>
                                                </div>
                                                <div class="col-md-6 mb-6">

                                                    <label>Collection Agent<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("AccountEmployeeID", null, "Please select Collection Employee", new { @class = "form-control select2 custom-select  AccountEmployeeID", @data_val = "true", @required = "required", @id = "AccountEmployeeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Collection Employee !!
                                                    </div>
                                                </div>
                                                <div class="col-md-3 mb-3 hide">
                                                    <label for="FundAccountID">Fund Account</label>

                                                    @Html.DropDownList("FundAccountID", null, "Please select", new { @class = "form-control select2 custom-select  FundAccountID", @data_val = "true", @id = "FundAccountID", @style = "width:50%;" })

                                                </div>


                                                
                                            </div>
                                            <div class="row col-md-12">
                                                <div class="col-md-3 mb-3">
                                                    <label for="Collection">Collection</label>
                                                    <input type="text" id="Collection" name="Collection" readonly class="form-control Collection" maxlength="150" tabindex="2" />
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="BookPickupDay">Book Pickup Day</label>
                                                    @Html.DropDownList("BookPickupDay", null, "Please select Book Pickup Day", new { @class = "form-control select2 custom-select  BookPickupDay", @data_val = "true", @required = "required", @id = "BookPickupDay", @style = "width:50%;" })

                                                </div>
                                            



                                                <div class="col-md-3 mb-3">
                                                    <label>Route </label>
                                                    @Html.DropDownList("RouteID", null, "Please select", new { @class = "form-control select2 custom-select  RouteID", @data_val = "true", @id = "RouteID", @style = "width:50%;" })
                                                </div>
                                                <div class="col-md-3 mb-3">
                                                    <label>Subscription Status <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("StatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  StatusTypeID", @data_val = "true", @required = "required", @id = "StatusTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Status
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="d-md-flex align-items-center mt-3">

                                                    <a href="@Url.Action("Index", "LoanSubscription")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>

                                                    <div class="ms-auto mt-3 mt-md-1 pull-right">

                                                        <button id="btnsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                                    </div>
                                                </div>
                                            </div>
                                            <br />

                                        </form>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane p-3" id="LoanPaymentSchedule" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-lg-3 hide">
                                                    <div class="form-group">
                                                        <label>primary</label>
                                                        <input class="form-control" id="ChitSchemeID" value="@ViewBag.ChitSchemeID" name="ChitSchemeID" />
                                                    </div>
                                                </div>
                                                <input type="text" id="LOANSCHEDULEDETAILIDX" value="0" name="LOANSCHEDULEDETAILIDX" class="LOANSCHEDULEDETAILIDX hide" />
                                                <table class='table table-striped table-bordered bootstrap-datatable' id="LOANSCHEDULEDETAIL">
                                                    <thead>
                                                        <tr>
                                                            <th colspan="4"><h4>Planned</h4></th>
                                                            <th colspan="4"><h4>Actuals</h4></th>

                                                        </tr>
                                                        <tr>
                                                            <th><label>Installmt. No</label></th>
