                    event.preventDefault();
                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        //position: "Center",
                        //timer:3500
                    }).then((result) => {
                        if (result.value) {

                            //$("#ClientMasterform").submit();
                            var ActionName = "SaveData";                            
                            var controllername = "ClientMaster";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#ClientMasterform').serialize();
                            var fileActionName = "SaveClientFiles";
                            var fileUpload = $("#filesupload").get(0); //document.getElementById("filesupload").files[0];//
