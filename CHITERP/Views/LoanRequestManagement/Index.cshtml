                            },
                            function (data, status) {

                                if (data == "") {
                                    Swal.fire({
                                        position: 'center',
                                        type: 'info',
                                        title: 'You are not authorize to Delete..!',
                                        showConfirmButton: true,
                                        //timer: 5500
                                    }).then((result) => {
                                        if (result.value) {
                                            var returnurl = "@Url.Action("Index", "LoanRequestManagement")";
                                            window.location.href = returnurl;
                                        }
                                    });
                                }
                                else {
                                    Swal.fire({
                                        position: 'center',
                                        type: 'success',
                                        title: 'Loan Request Details Deleted Successfully ..!', //You are not authorize to Delete..!',
                                        showConfirmButton: true,
                                        //timer: 3500
                                    }).then((result) => {
                                        if (result.value) {
                                            var returnurl = "@Url.Action("Index", "LoanRequestManagement")";
                                            window.location.href = returnurl;
                                        }
                                    });
                                }

                            });
                    }
                    else if (result.dismiss === 'cancel') { return false; }
                });

