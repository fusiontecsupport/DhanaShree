
@using CHITERP.Models;
@model CHITERP.Models.CompanyOffice

@{
    ViewBag.Title = "Office Master";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            @Html.Raw(ViewBag.msg)

            <div class="card">
                <div class="card-body">

                    <h3 class="card-title mb-3 pb-3 border-bottom">@ViewBag.Title</h3>
                    <form action="@Url.Content("~/OfficeManagement/SaveData")" method="post" data-flag="0" class="needs-validation OfficeMasterform" id="OfficeMasterform" name="OfficeMasterform" novalidate onsubmit="return ValidateMyform(this,event);">

                        <div class="row">
                            <div class="col-md-2 mb-2 hide">
                                <label for="OfficeID">Id</label>
                                @if (Model != null)
                                {
                                    <input type="text" id="OfficeID" name="OfficeID" value="@Model.OfficeID" class="form-control OfficeID" />
                                }
                                else
                                {
                                    <input type="text" id="OfficeID" name="OfficeID" value="0" class="form-control OfficeID" />
                                }
                            </div>

                            <div class="col-md-4 mb-4">
                                <label for="OfficeTypeID">Office Type <span class="text-danger">*</span></label>

                                @Html.DropDownList("OfficeTypeID", null, "Please Select Office Type", new { @class = "form-control custom-select select2  OfficeTypeID", @data_val = "true", @required = "required", @id = "OfficeTypeID", @name = "OfficeTypeID" })
                                <div class="invalid-feedback">
                                    Please Select Office Type!!
                                </div>
                            </div>
                            <div class="col-md-4 mb-4">
                                <label for="CONTACTPERSON">Name <span class="text-danger">*</span></label>

                                @if (Model != null)
                                {
                                    <input type="text" id="OfficeName" value="@Model.OfficeName" name="OfficeName" class="form-control OfficeName" placeholder="Office Name" required maxlength="250" />
                                    <div class="invalid-feedback">
                                        Please Enter Office Name !!
                                    </div>
                                }
                                else
                                {
                                    <input type="text" id="OfficeName" name="OfficeName" class="form-control OfficeName" required placeholder="Office Name" maxlength="100" tabindex="1" />
                                    <div class="invalid-feedback">
                                        Please Enter Office Name !!
                                    </div>
                                }

                            </div>

                        </div>


                        <div class="row">


                            <div class="col-md-4 mb-4">
                                <div class="form-group">
                                    <label for="CPADDRESS1">Address 1</label>

                                    @if (Model != null)
                                    {
                                        <input type="text" id="AddressLine1" name="AddressLine1" value="@Model.AddressLine1" class="form-control AddressLine1" placeholder="Address Line 1" required maxlength="100" tabindex="13" />
                                        <div class="invalid-feedback">
                                            Please Enter Address Line 1 !!
                                        </div>
                                    }
                                    else
                                    {
                                        <input type="text" id="AddressLine1" name="AddressLine1" class="form-control AddressLine1" placeholder="Address Line 1" maxlength="100" required tabindex="13" />
                                        <div class="invalid-feedback">
                                            Please Enter Address Line 1 !!
                                        </div>
                                    }

                                </div>


                            </div>

                            <div class="col-md-4 mb-4">
                                <div class="form-group">
                                    <label for="CPADDRESS2">Address 2</label>

                                    @if (Model != null)
                                    {
                                        <input type="text" id="AddressLine2" name="AddressLine2" value="@Model.AddressLine2" class="form-control AddressLine2" placeholder="Address Line 2" maxlength="100" tabindex="13" />
                                        <div class="invalid-feedback">
                                            Please Enter Address Line 2 !!
                                        </div>
                                    }
                                    else
                                    {
                                        <input type="text" id="AddressLine2" name="AddressLine2" class="form-control AddressLine2" placeholder="Address Line 2" maxlength="100" tabindex="13" />
                                        <div class="invalid-feedback">
                                            Please Enter Address Line 2 !!
                                        </div>
                                    }

                                </div>


                            </div>


                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <label for="CountryID">Country <span class="text-danger">*</span></label>
                                @Html.DropDownList("CountryID", null, "Please Select Country", new { @class = "form-control custom-select select2  CountryID", @data_val = "true", @required = "required", @id = "CountryID", @name = "CountryID", @onchange = "GetCityList();" })
                                <div class="invalid-feedback">
                                    Please Select Country !!
                                </div>
                            </div>

                            <div class="col-md-4 mb-4">
                                <label for="CityID">City <span class="text-danger">*</span></label>
                                @Html.DropDownList("CityID", null, "Please Select City", new { @class = "form-control custom-select select2  CityID", @data_val = "true", @required = "required", @id = "CityID", @name = "CityID", @onchange = "GetLocationList();" })
                                <div class="invalid-feedback">
                                    Please Select City !!
                                </div>
                            </div>

                            <div class="col-md-4 mb-4">
                                <label for="LocalityID">Location <span class="text-danger">*</span></label>
                                @Html.DropDownList("LocalityID", null, "Please Select Location", new { @class = "form-control custom-select select2  LocalityID", @data_val = "true", @required = "required", @id = "LocalityID", @name = "LocalityID" })
                                <div class="invalid-feedback">
                                    Please Select Location !!
                                </div>
                            </div>

                            <div class="col-md-4 mb-4">
                                <div class="form-group">
                                    <label for="CPPINCD">Pincode<span class="text-danger">*</span></label>

                                    @if (Model != null)
                                    {
                                        <input type="text" id="PIN" name="PIN" value="@Model.PIN" class="form-control PIN" placeholder="Pincode" required maxlength="6" tabindex="13" />
                                        <div class="invalid-feedback">
                                            Please Enter Pincode!!
                                        </div>
                                    }
                                    else
                                    {
                                        <input type="text" id="PIN" name="PIN" class="form-control PIN" placeholder="Pincode" required maxlength="6" tabindex="13" />
                                        <div class="invalid-feedback">
                                            Please Enter Pincode!!
                                        </div>
                                    }

                                </div>


                            </div>

                            <div class="col-md-4 mb-4">

                                <label>Status <span class="text-danger">*</span></label>
                                @Html.DropDownList("DISPSTATUS", null, "Please select Status", new { @class = "form-control select2 custom-select  DISPSTATUS", @data_val = "true", @required = "required", @id = "DISPSTATUS", @tabindex = "10", @style = "width:50%;" })
                                <div class="invalid-feedback">
                                    Please Select Status !!
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="d-md-flex align-items-center mt-3">

                                    <a href="@Url.Action("Index", "OfficeManagement")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>

                                    <div class="ms-auto mt-3 mt-md-1 pull-right">

                                        <button id="btnsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
                <!---->
            </div>
        </div>
    </div>
</div>





@section Scripts {

    <script type="text/javascript">

        function ValidateMyform(form, event) {
            flag = true;
            i = 0;
            var frmflag = $(form).attr('data-flag');
            //alert(frmflag);
            var form = document.getElementById('OfficeMasterform');
            var inputs = form.getElementsByTagName('input');
            var forms = document.getElementsByClassName('needs-validation');

            if (form.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
                flag = false;
            }
            else {
                form.classList.add('was-validated'); flag = true;
            }

            if (flag) {
                //alert(flag);
                if (frmflag == 0) {
                    event.preventDefault(); //to prevent submitting
                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        //position: "Center",
                        //timer:3500
                    }).then((result) => {
                        if (result.value) {

                            //$("#OfficeMasterform").submit();
                            var ActionName = "SaveData";
                            var controllername = "OfficeManagement";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#OfficeMasterform').serialize();
                            submitFormData(ActionName, controllername, pagetitle, formData);

                        } else if (result.dismiss === 'cancel') {


                            return false;

                        }
                    });

                }
            }
            else {
                return false;
            }
        }


        $(window).bind("load", function () {
            if ($(".OfficeID").val() == "") {
                $(".OfficeID").val("0");
            }


        });

        $(document).ready(function () {

            if ($('#OfficeID').val() == "") {

                $('#OfficeID').val("0");

                if ($('#CreatedDt').val() == "") {
                    var date = new Date();
                    $('#CreatedDt').val(date);
                }
            }
            else {

                if ($('#UpdatedDt').val() == "") {
                    var date = new Date();
                    $('#UpdatedDt').val(date);
                }
            }
            //ClientTypeChange();

        });

        function GetCityList() {
