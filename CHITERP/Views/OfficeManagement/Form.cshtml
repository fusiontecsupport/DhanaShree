                type: 'post',
                url: '@Url.Action("Get_City_List", "OfficeManagement")/' + countryid, // we are calling json method
                dataType: 'json',
                success: function (data) {
                    var i = 0;
                    //if (data != "") {
                    //    $(".CityID").append("<option value=''>Please Select City</option>");
                    //}
                    //else {
                    //    $tr.find(".CityID").append("<option value=''>No Record Found</option>");
                    //}
                    $.each(data, function (k, v) {
                        //if (i == 0) {

                        //    $(".CityID").append("<option value=" + v.CityID + " selected>" + v.CityName + " </option>");
                        //}
                        //else {
                            $(".CityID").append("<option value=" + v.CityID + ">" + v.CityName + "</option>");
                        //}
                        i++;
                    })
                },
                complete: function () {
                    GetLocationList();
                },
                error: function (ex) {
                    //alert('Failed to data ' + ex);
                }
            });
            }



        }

        function GetLocationList() {
            var cityid = $(".CityID").val();
            $(".LocalityID").empty();
            $(".LocalityID").append("<option value=''>Please Select Location</option>");

            if (cityid != null && cityid != "0" ) {
                  //alert(mcode);
            $.ajax({
                type: 'post',
                url: '@Url.Action("Get_Location_List", "OfficeManagement")/' + cityid, // we are calling json method
                dataType: 'json',
                success: function (data) {
                    //if (data != "") {
                    //    $(".LocalityID").append("<option value=''>Please Select Location</option>");
                    //}
                    var i = 0;
                    $.each(data, function (k, v) {
                        //if (i == 0) {

                        //    $(".LocalityID").append("<option value=" + v.LocalityID + " selected>" + v.LocalityName + " </option>");
                       // }
                        //else {
                            $(".LocalityID").append("<option value=" + v.LocalityID + ">" + v.LocalityName + "</option>");
                       // }
                        i++;
                    })
                },
                complete: function () {
                },
                error: function (ex) {
                    //alert('Failed to data ' + ex);
                }
            });
            }



        }


        function checkemail(email) {
            //alert(email);
            if (email != "") {
                //var regex = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;
                var regex = /^([\w-\.]+)@@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$/;
                if (!regex.test(email)) {
                    Swal.fire({
                        text: 'Please Enter Valid e MailId',
                        type: 'warning',
                        //timer: 2500,
                        showConfirmButton: true
                    }).then(function () {
                        $('.CPEMAILID').focus();
                    });
                }
            }
        }

    </script>

}

