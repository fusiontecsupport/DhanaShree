@{
    ViewBag.Title = "Dashboard";
}

<style type="text/css">
    .radius-10 {
        border-radius: 10px !important;
    }

    .border-info {
        border-left: 5px solid #1e88e5 !important;
    }

    .border-danger {
        /*border-left: 5px solid #fd3550 !important;*/
        border-left: 5px solid #ffb22b !important;
    }

    .border-success {
        /* border-left: 5px solid #15ca20 !important;*/
        border-left: 5px solid #7460ee !important;
    }

    .border-warning {
        /* border-left: 5px solid #ffc107 !important;*/
        border-left: 5px solid #e6294b !important;
    }

    .border-demo {
        border-left: 5px solid #9c27b0 !important;
    }

    .border-Quotation {
        border-left: 5px solid #428bca !important;
    }

    .card {
        position: relative;
        display: flex;
        flex-direction: column;
        min-width: 0;
        word-wrap: break-word;
        background-color: #fff;
        background-clip: border-box;
        border: 0px solid rgba(0, 0, 0, 0);
        border-radius: .25rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 6px 0 rgb(218 218 253 / 65%), 0 2px 6px 0 rgb(206 206 238 / 54%);
    }

    .bg-gradient-scooter {
        background: #17ead9;
        background: -webkit-linear-gradient( 45deg, #17ead9, #6078ea) !important;
        background: linear-gradient( 45deg, #17ead9, #6078ea) !important;
    }

    .widgets-icons-2 {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #ededed;
        font-size: 27px;
        border-radius: 10px;
        margin-top: -1px;
    }

    .rounded-circle {
        border-radius: 50% !important;
    }

    .text-white {
        color: #fff !important;
    }

    .ms-auto {
        margin-left: auto !important;
    }

    .bg-gradient-bloody {
        background: #f54ea2;
        background: -webkit-linear-gradient( 45deg, #f54ea2, #ff7676) !important;
        background: linear-gradient( 45deg, #f54ea2, #ff7676) !important;
    }

    .bg-gradient-ohhappiness {
        background: #00b09b;
        background: -webkit-linear-gradient( 45deg, #00b09b, #96c93d) !important;
        background: linear-gradient( 45deg, #00b09b, #96c93d) !important;
    }

    .bg-gradient-blooker {
        background: #ffdf40;
        background: -webkit-linear-gradient( 45deg, #ffdf40, #ff8359) !important;
        background: linear-gradient( 45deg, #ffdf40, #ff8359) !important;
    }

    .bg-gradient-demo {
        background: #9c27b0;
        background: -webkit-linear-gradient( 45deg, #9c27b0, #ff8359) !important;
        background: linear-gradient( 45deg, #9c27b0, #ff8359) !important;
    }

    .bg-gradient-Quotation {
        background: #428bca;
        background: -webkit-linear-gradient( 45deg, #428bca, #6bc8d7) !important;
        background: linear-gradient( 45deg, #428bca, #6bc8d7) !important;
    }

    .funnel {
        font-size: 24px !important;
        font-weight: 700 !important;
    }
    /* Gauge CSS */
    .gauge {
        position: relative;
        border-radius: 50%/100% 100% 0 0;
        background-color: var(--color, #a22);
        overflow: hidden;
        width: 350px;
        left: 6%;
    }

        .gauge:before {
            content: "";
            display: block;
            padding-top: 50%; /* ratio of 2:1*/
        }

        .gauge .chart {
            overflow: hidden;
        }

        .gauge .mask {
            position: absolute;
            left: 20%;
            right: 20%;
            bottom: 0;
            top: 40%;
            background-color: #fff;
            border-radius: 50%/100% 100% 0 0;
        }

        .gauge .percentage {
            position: absolute;
            top: -1px;
            left: -1px;
            bottom: 0;
            right: -1px;
            background-color: var(--background, #aaa);
            transform: rotate(var(--rotation));
            transform-origin: bottom center;
            transition-duration: 600;
        }

        /*.gauge:hover {
            --rotation: 100deg;
        }*/

        .gauge .value {
            /*position: absolute;
            bottom: 0%;
            left: 0;
            width: 100%;
            text-align: center;*/
            text-align: center;
            position: absolute;
            bottom: 0%;
            left: 0;
            width: 100%;
            font-size: 24px;
            font-weight: 700;
        }

        .gauge .min {
            position: absolute;
            bottom: 0;
            left: 5%;
        }

        .gauge .max {
            position: absolute;
            bottom: 0;
            right: 5%;
        }
</style>
<link href="~/assets/libs/morris.js/morris.css" rel="stylesheet">
<div class="container-fluid">
    

    <div class="card">

        <div class="card-body">
            <div class="row">
                <div class="col-12">
                    <div class="card-header border-bottom" style="background-color:white;">
                        <div class="d-flex no-block align-items-center mb-0">
                            <h3 class="card-title text-dark-primary"><i class="fa fa-dashboard fa-fw"></i>@ViewBag.Title</h3>

                        </div>
                    </div>
                    <br />
                    <div class="col-lg-12" style="margin-top:10px">

                        <form action="#" method="post" accept-charset="utf-8" id="LoanSubscriptionFilterform" data-ng-controller="LoanSubscription" name="LoanSubscriptionFilterform">
                            <div class="row">
                                <div class="col-md-2 mb-2">
                                    <label for="from">From Date</label>
                                    <input id="empid" type="text" value="@System.Web.HttpContext.Current.Session["EMPLID"]" required name="empid" class="form-control hide empid" />
                                    <input id="usrid" type="text" value="@System.Web.HttpContext.Current.Session["CUSRID"]" required name="usrid" class="form-control hide usrid" />
                                    <input id="from" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",System.Web.HttpContext.Current.Session["DBSDATE"])" required name="from" class="form-control from" />
                                    <div class="invalid-feedback">
                                        Please Select From Date !!
                                    </div>
                                </div>
                                <div class="col-md-2 mb-2">
                                    <label for="from">To Date</label>

                                    <input id="to" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",System.Web.HttpContext.Current.Session["DBEDATE"])" required name="to" class="form-control to" />
                                    <div class="invalid-feedback">
                                        Please Select To Date !!
                                    </div>
                                </div>
                                <div class="col-md-2 mb-2">
                                    <br />
                                    <input type="submit" name="submit" value="Search" class="btn btn-info btn-sm" />
                                </div>
                            </div>
                        </form>

                    </div>
                    <br />
                    <!-- Start Stacked Bar Chart -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h4 class="card-title">Month wise Summary</h4>                                    
                                    <div id="morris-bar-chart"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- End Stacked Bar Chart -->
                    <div class="row">
                        <div id="dbrpt" class="dbrpt">

                        </div>
                        </div>
                    </div>
                </div>
        </div>


    </div>

</div>


@section Scripts {
    
    
    <script type="text/javascript">
    $(document).ready(function () {
        $(".preloader").show();
            stackedbarchart();
            var baseUrl = $("#BaseUrl").data("baseurl");
            var usrid = $(".usrid").val();
            var empid = $(".empid").val();
            var fdt = $(".from").val();
            var tdt = $(".to").val();
            var ids = usrid + '~' + empid + '~' + fdt + '~' + tdt;
            var url = '@Url.Action("DBTodayCollectionDtl", "Home")/?id=' + ids;
            $(".dbrpt").html("");
            $.ajax({
                type: 'post',
                url: url,
                /*dataType: 'json',*/
                success: function (data) {
                    $(".dbrpt").html(data);
                },
                error: function (ex) {
                    //alert('Failed to data ' + ex);
                }
            });
            $(".preloader").hide();
        });

        function stackedbarchart() {
            var baseUrl = $("#BaseUrl").data("baseurl");
            var usrid = $(".usrid").val();
            var empid = $(".empid").val();
            var fdt = $(".from").val();
            var tdt = $(".to").val();
            var ids = usrid + '~' + empid + '~' + fdt + '~' + tdt;
            var url = '@Url.Action("GetDashboardDtl", "Home")/?id=' + ids;

            $.getJSON(url, function (data) {
                if (data.length > 0) {
                    
                    Morris.Bar({
                        element: 'morris-bar-chart',
                        data: data,
                        xkey: 'yrmon',
                        ykeys: ['ColnAmt', 'PymtAmt'],
                        labels: ['Coln.Amt.', 'Pymt.Amt.'],

                        barColors: ['#6993ff', '#4fc3f7', '#ee9d01', '#f64e60', 'yellowgreen'],//['#fc4b6c', '#00acc1', '#1e88e5'],
                        hideHover: 'auto',
                        gridLineColor: '#eef0f2',
                        resize: true
                    });
                }
            });

          
            // Stacked Bar Chart -------> BAR CHART

    }


    </script>
    <script src="~/assets/libs/raphael/raphael.min.js"></script>
    <script src="~/assets/libs/morris.js/morris.min.js"></script>

}