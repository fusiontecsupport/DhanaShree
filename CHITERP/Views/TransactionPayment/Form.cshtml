                                                <input type="number" id="GeneratedAmount" min="0.00" step="0.01" name="GeneratedAmount" class="form-control GeneratedAmount" required maxlength="100" value="@Model.GeneratedAmount" tabindex="2" />
                                            }
                                            else
                                            {
                                                <input type="number" id="GeneratedAmount" min="0.00" step="0.01" name="GeneratedAmount" class="form-control GeneratedAmount" required maxlength="100" tabindex="2" />
                                            }

