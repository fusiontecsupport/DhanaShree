                                                {
                                                    <input id="GenerratedDate" type="date" min="2015-01-01" max="2099-12-31" name="GenerratedDate" required class="form-control GenerratedDate" />
                                                    <div class="invalid-feedback">
                                                        Please Select Date !!
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <input id="GenerratedDate" type="date" min="2015-01-01" max="2099-12-31" name="GenerratedDate" required class="form-control GenerratedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
