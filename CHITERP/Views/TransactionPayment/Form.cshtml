                                            @Html.DropDownList("PaymentMode", null, "-- Select --", new { @class = "form-control select2 custom-select  PaymentMode", @data_val = "true", @required = "required", @onchange = "ChkChequeDtl();", @id = "PaymentMode", @style = "width:50%;" })
                                            <div class="invalid-feedback">
                                                Please Select Payment Mode !!
                                            </div>
                                        </div>
                                        <div class="col-md-2 mb-2">

