@using CHITERP.Models;
@model CHITERP.Models.TransactionPaymentList
@{
    ViewBag.Title = "Transaction Payment Entry";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">

                <div class="card-header bg-info">
                    <h4 class="mb-0 text-white">@ViewBag.Title </h4><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                </div>
                <form action="@Url.Content("~/TransactionPayment/Savedata")" method="post" data-flag="0" class="needs-validation TransactionPaymentform" id="TransactionPaymentform" name="TransactionPaymentform" novalidate onsubmit="return ValidateMyform(this,event);">

                    <div class="card-body">
                        <div class="row">
                            <div class="row col-md-12">

                                <div class="row">
                                    <div class="row col-md-12">
                                        <div class="col-md-2 mb-2 hide">
                                            <label for="PaymentListID">Transaction Id</label>

                                            @if (Model != null)
                                            {

                                                <input type="text" id="PaymentListID" name="PaymentListID" value="@Model.PaymentListID" class="form-control PaymentListID" />
                                            }
                                            else
                                            {
                                                <input type="text" id="PaymentListID" name="PaymentListID" value="@ViewBag.TranID" class="form-control PaymentListID" />
                                            }

                                        </div>
                                        <div class="col-md-2 mb-2">
                                            <label for="ProductTypeTypeID">Product<span class="text-danger">*</span></label>
                                            @Html.DropDownList("ProductTypeTypeID", null, "-- Select --", new { @class = "form-control select2 custom-select  ProductTypeTypeID", @data_val = "true", @required = "required", @id = "ProductTypeTypeID", @style = "width:50%;", @onchange = "LoadSubTrnTypsNPrdSubs();" })
                                            <div class="invalid-feedback">
                                                Please Select Product !!
                                            </div>

                                        </div>
                                        <div class="col-md-4 mb-4">
                                            <label for="SubscriptionID">Subscription<span class="text-danger">*</span></label>
                                            @Html.DropDownList("SubscriptionID", null, "-- Select --", new { @class = "form-control select2 custom-select  SubscriptionID", @data_val = "true", @required = "required", @id = "SubscriptionID", @style = "width:50%;" })
                                            <div class="invalid-feedback">
                                                Please Select Subscription Details!!
                                            </div>
                                        </div>
                                        <div class="col-md-2 mb-2">
                                            <label for="TransactionCategory">Transaction Category<span class="text-danger">*</span></label>
                                            @Html.DropDownList("TransactionCategory", null, "-- Select --", new { @class = "form-control select2 custom-select  TransactionCategory", @data_val = "true", @required = "required", @id = "TransactionCategory", @onchange = "LoadSubTrnTyps();", @style = "width:50%;" })
                                            <div class="invalid-feedback">
                                                Please Select Transaction Category !!
                                            </div>
                                        </div>

                                        <div class="col-md-2 mb-2">
                                            <label for="SubsTranCategory">Sub Category<span class="text-danger">*</span></label>
                                            @Html.DropDownList("SubsTranCategory", null, "-- Select --", new { @class = "form-control select2 custom-select  SubsTranCategory", @data_val = "true", @required = "required", @id = "SubsTranCategory", @style = "width:50%;" })
                                            <div class="invalid-feedback">
                                                Please Select Category !!
                                            </div>
                                        </div>
                                        <div class="col-md-2 mb-2 hide">
                                            <label for="TransactionType">Transaction Type<span class="text-danger">*</span></label>
                                            @Html.DropDownList("TransactionType", null, "-- Select --", new { @class = "form-control select2 custom-select  TransactionType", @data_val = "true", @id = "TransactionType", @style = "width:50%;" })
                                            <div class="invalid-feedback">
                                                Please Select Transaction Type !!
                                            </div>
                                        </div>
                                        <div class="col-md-2 mb-2">
                                            <label for="GenerratedDate">Payment Date</label>


