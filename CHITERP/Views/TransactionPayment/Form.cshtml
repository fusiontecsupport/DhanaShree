                                            {
                                                string pdatetime = Convert.ToString(Model.GenerratedDate);
                                                if ((pdatetime != null && pdatetime != ""))
                                                {
                                                    var param = pdatetime.Split(' ');
                                                    DateTime pdate = Convert.ToDateTime(param[0]).Date;
