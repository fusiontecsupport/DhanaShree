@{
    ViewBag.Title = "Customer Accounts Summary - Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-12">
                    <div class="card-header border-bottom" style="background-color:white;">
                        <div class="d-flex no-block align-items-center mb-0">
                            <h3 class="card-title text-dark-primary"><i class="fa fa-dashboard fa-fw"></i>@ViewBag.Title</h3>
                        </div>
                    </div>
                    <br />
                    <div class="col-lg-12" style="margin-top:10px">
                        <form target="_blank" action="@Url.Action("GeneratePartyAcctDetailsReportPDF", "ExcelReports")/" method="post" accept-charset="utf-8" id="FinExcelRptForm" data-ng-controller="myController" name="FinExcelRptForm">
                            <div class="row">
                                <div class="col-md-6 mb-6">
                                    <label class=control-label col-form-label">Organization/Person</label>

                                    @Html.DropDownList("FPersonID", null, "Please Select Organization/Person", new
                                    {
                                        @class = "form-control select2 custom-select  FPersonID",
                                        @data_val = "true",
                                        @required = "required",
                                        @id = "FPersonID",
                                        })
                                    <div class="invalid-feedback">
                                        Please Select Organization/Person !!
                                    </div>

                                </div>

                                <div class="col-md-2 mb-2">
                                    <br />
                                    <input type="submit" name="submit" value="Download PDF Report" class="btn btn-info btn-sm" />
                                </div>
                            </div>
                        </form>

                    </div>
                    <br />

                </div>
            </div>
        </div>


    </div>

</div>


@section Scripts {


    <script type="text/javascript">
        $(document).ready(function () {

        });



    </script>

}