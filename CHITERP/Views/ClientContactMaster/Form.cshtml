@section Scripts {

    <script type="text/javascript">

        function ValidateMyform(form, event) {
            flag = true;
            i = 0;
            var frmflag = $(form).attr('data-flag');
            //alert(frmflag);
            var form = document.getElementById('ClientContactMasterform');
            var inputs = form.getElementsByTagName('input');
            var forms = document.getElementsByClassName('needs-validation');

            if (form.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
                flag = false;
            }
            else {
                form.classList.add('was-validated'); flag = true;
            }

            if (flag) {
                if (frmflag == 0) {
                    event.preventDefault();
                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        //position: "Center",
                        //timer:3500
                    }).then((result) => {
                        if (result.value) {

                            //$("#ContactMasterform").submit();
                            var ActionName = "SaveData";
                            var controllername = "ClientContactMaster";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#ClientContactMasterform').serialize();
                            submitFormData(ActionName, controllername, pagetitle, formData);

                        } else if (result.dismiss === 'cancel') {


                            return false;

                        }
                    });

                }
            }
            else {
                return false;
            }
        }



        $(window).bind("load", function () {
            if ($(".CONTID").val() == "") {
                $(".CONTID").val("0");
            }


        });

        $(document).ready(function () {

            if ($('#CONTID').val() == "") {

                $('#CONTID').val("0");

                if ($('#CreatedDt').val() == "") {
                    var date = new Date();
                    $('#CreatedDt').val(date);
                }
            }
            else {

                if ($('#UpdatedDt').val() == "") {
                    var date = new Date();
                    $('#UpdatedDt').val(date);
                }
            }
            

        });

        

        function checkemail(email) {
            //alert(email);
            if (email != "") {
                //var regex = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;
                var regex = /^([\w-\.]+)@@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$/;
                if (!regex.test(email)) {
                    Swal.fire({
                        text: 'Please Enter Valid e MailId',
                        type: 'warning',
                        timer: 2500,
                        showConfirmButton: true
                    }).then(function () {
                        $('.CPEMAILID').focus();
                    });
                }
            }
        }

    </script>

}

