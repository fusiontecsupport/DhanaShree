        function ValidateMyform(form, event) {
            flag = true;
            i = 0;
            var ids = $("#BookVerificationListID").val();
            var frmflag = $(form).attr('data-flag');
            //alert(frmflag);
            var form = document.getElementById('TransactionBookVerificationform');
            var inputs = form.getElementsByTagName('input');
            var forms = document.getElementsByClassName('needs-validation');

            if (form.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
                flag = false;
            }
            else {
                form.classList.add('was-validated'); flag = true;
            }

            if (flag) {
                if (frmflag == 0) {
                    event.preventDefault(); //to prevent submitting


                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        position: "Center",
                    }).then((result) => {
                        if (result.value) {
                            flag = true;
                            var ActionName = "SaveData";
                            var controllername = "TransactionBookVerification";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#TransactionBookVerificationform').serialize();
                            //submitFormData(ActionName, controllername, pagetitle, formData);
                            var fileActionName = "SaveBookVerificationFiles";
                            var fileUpload = $("#filesupload").get(0); //document.getElementById("filesupload").files[0];//
                            var files = fileUpload.files;
                            //alert(trandid);
                            // Create FormData object
                            var fileData = new FormData();
                            //fileData.append("trandid", trandid);
                            // Looping over all files and add it to FormData object
                            for (var i = 0; i < files.length; i++) {
                                //alert(files[i].name);
                                fileData.append(files[i].name, files[i]);
                            }

                            //submitFormFileData(ActionName, controllername, pagetitle, formData, fileData, fileActionName, ids);
                            var returl="@Url.Action("Form", "TransactionBookVerification")";
                            submitFormData(ActionName, controllername, pagetitle + '~' + returl, formData, fileData, fileActionName, ids);


                        }
                        else if (result.isDenied) {
                            Swal.fire('Changes are not saved', '', 'info')
                            flag = false;
                            return false;
                        }
                    });
                }
            }
            else {
                return false;
            }
        }




