@using CHITERP.Data;
@using CHITERP.Models;
@model CHITERP.Models.TranBookVrfcnList
@{
    ViewBag.Title = "Transaction Book Verification List - Entry";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">

                <div class="card-header bg-info">
                    <h4 class="mb-0 text-white">@ViewBag.Title </h4><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                </div>
                <form action="@Url.Content("~/TransactionBookVerification/Savedata")" method="post" data-flag="0" class="needs-validation TransactionBookVerificationform" id="TransactionBookVerificationform" name="TransactionBookVerificationform" novalidate onsubmit="return ValidateMyform(this,event);">

                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">

                                <div class="row">
                                    <div class="col-md-2 mb-2 hide">
                                        <label for="BookVerificationListID">Transaction Id</label>

                                        @if (Model.tranbookvfcnlst.Count > 0)
                                        {

                                            <input type="text" id="BookVerificationListID" name="BookVerificationListID" value="@Model.tranbookvfcnlst[0].BookVerificationListID" class="form-control BookVerificationListID" />
                                        }
                                        else
                                        {
                                            <input type="text" id="BookVerificationListID" name="BookVerificationListID" value="@ViewBag.TranID" class="form-control BookVerificationListID" />

                                        }

                                        <input type="text" id="F_BookVerificationID" name="F_BookVerificationID" class="form-control F_BookVerificationID" />
                                        <input id="F_BookEntryDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="" name="F_BookEntryDate" class="form-control F_BookEntryDate" />
                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <label for="ProductTypeID">Product<span class="text-danger">*</span></label>
                                        @Html.DropDownList("ProductTypeID", null, "-- Select --", new { @class = "form-control select2 custom-select  ProductTypeID", @data_val = "true", @required = "required", @id = "ProductTypeID", @style = "width:50%;", @onchange = "LoadProdDtls();" })
                                        <div class="invalid-feedback">
                                            Please Select Product !!
                                        </div>

                                    </div>

                                    <div class="col-md-5 mb-5">
                                        <label for="ProductID">Subscription<span class="text-danger">*</span></label>
                                        @Html.DropDownList("ProductID", null, "-- Select --", new { @class = "form-control select2 custom-select  ProductID", @data_val = "true", @required = "required", @id = "ProductID", @style = "width:50%;", @onchange = "LoadBooks();" })
                                        <div class="invalid-feedback">
                                            Please Select Subscription Details!!
                                        </div>
                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <label for="BookID">Book<span class="text-danger">*</span></label>
                                        @Html.DropDownList("BookID", null, "-- Select --", new { @class = "form-control select2 custom-select  BookID", @data_val = "true", @required = "required", @id = "BookID", @style = "width:50%;" })
                                        <div class="invalid-feedback">
                                            Please Select Book !!
                                        </div>

                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label for="GeneratedDate">Book Verification Generation Date</label>


                                        @if (Model != null)
                                        {
                                            string pdatetime = Convert.ToString(Model.tranbookvfcnlst[0].GeneratedDate);
                                            if ((pdatetime != null && pdatetime != ""))
                                            {
                                                var param = pdatetime.Split(' ');
                                                DateTime pdate = Convert.ToDateTime(param[0]).Date;
                                                <input id="GeneratedDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@String.Format("{0:yyyy-MM-dd}",pdate)" required name="GeneratedDate" class="form-control GeneratedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
                                            else
                                            {
                                                <input id="GeneratedDate" type="date" max="2099-12-31" min="2015-01-01" readonly name="GeneratedDate" required class="form-control GeneratedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <input id="GeneratedDate" type="date" max="2099-12-31" min="2015-01-01" readonly name="GeneratedDate" required class="form-control GeneratedDate" />
                                            <div class="invalid-feedback">
                                                Please Select Date !!
                                            </div>
                                        }
                                    </div>



                                </div>

                                <div class="row">
                                    <div class="col-md-2 mb-2">
                                        <label for="CollectedDate">Book Collected Date</label>


                                        @if (Model != null)
                                        {
                                            string pdatetime = Convert.ToString(Model.tranbookvfcnlst[0].CollectedDate);
                                            if ((pdatetime != null && pdatetime != ""))
                                            {
                                                var param = pdatetime.Split(' ');
                                                DateTime pdate = Convert.ToDateTime(param[0]).Date;
                                                <input id="CollectedDate" type="date" max="2099-12-31" min="2015-01-01" value="@String.Format("{0:yyyy-MM-dd}",pdate)" required name="CollectedDate" class="form-control CollectedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
                                            else
                                            {
                                                <input id="CollectedDate" type="date" max="2099-12-31" min="2015-01-01" name="CollectedDate" required class="form-control CollectedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <input id="CollectedDate" type="date" max="2099-12-31" min="2015-01-01" name="CollectedDate" required class="form-control CollectedDate" />
                                            <div class="invalid-feedback">
                                                Please Select Date !!
                                            </div>
                                        }
                                    </div>


                                    <div class="col-md-2 mb-2">
                                        <label for="F_OldReceiptID">Old Receipt Reference<span class="text-danger">*</span></label>
                                        @Html.DropDownList("F_OldReceiptID", null, "-- Select --", new { @class = "form-control select2 custom-select  F_OldReceiptID", @data_val = "true", @required = "required", @id = "F_OldReceiptID", @style = "width:50%;", @onchange = "AssignReceiptAmt()" })

                                        <div class="invalid-feedback">
                                            Please Select Old Receipt Reference!!
                                        </div>
                                    </div>
                                    <div class="col-md-2 mb-2">

                                        <label for="F_OldReceiptAmount">Old Receipt Amount<span class="text-danger">*</span></label>

                                        @if (Model != null)
                                        {
                                            <input type="number" id="F_OldReceiptAmount" min="0.00" step="0.01" name="F_OldReceiptAmount" class="form-control F_OldReceiptAmount" required maxlength="100" onchange="CalcDiffAmt();" tabindex="2" readonly />
                                        }
                                        else
                                        {
                                            <input type="number" id="F_OldReceiptAmount" min="0.00" step="0.01" name="F_OldReceiptAmount" class="form-control F_OldReceiptAmount" required maxlength="100" tabindex="2" onchange="CalcDiffAmt();" readonly />
                                        }

                                        <div class="invalid-feedback">
                                            Please Enter Amount!!
                                        </div>

                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <label for="F_BookVerificationFindingID">Book Verification Finding<span class="text-danger">*</span></label>
                                        @Html.DropDownList("F_BookVerificationFindingID", null, "-- Select --", new { @class = "form-control select2 custom-select  F_BookVerificationFindingID", @data_val = "true", @required = "required", @id = "F_BookVerificationFindingID", @style = "width:50%;" })
                                        <div class="invalid-feedback">
                                            Please Select Book Verification Finding!!
                                        </div>
                                    </div>
                                    <div class="col-md-2 mb-2">

                                        <label for="F_BookAmount">Book Amount<span class="text-danger">*</span></label>

                                        @if (Model != null)
                                        {
                                            <input type="number" id="F_BookAmount" min="0.00" step="0.01" name="F_BookAmount" class="form-control F_BookAmount" required maxlength="100" onchange="CalcDiffAmt();" tabindex="2" />
                                        }
                                        else
                                        {
                                            <input type="number" id="F_BookAmount" min="0.00" step="0.01" name="F_BookAmount" class="form-control F_BookAmount" required maxlength="100" tabindex="2" onchange="CalcDiffAmt()" />
                                        }

                                        <div class="invalid-feedback">
                                            Please Enter Amount!!
                                        </div>

                                    </div>

                                    <div class="col-md-2 mb-2">
                                        <label for="ReturnedDate">Book Returned Date </label>
                                        @if (Model != null)
                                        {
                                            string pdatetime = Convert.ToString(Model.tranbookvfcnlst[0].ReturnedDate);
                                            if ((pdatetime != null && pdatetime != ""))
                                            {
                                                var param = pdatetime.Split(' ');
                                                DateTime pdate = Convert.ToDateTime(param[0]).Date;
                                                <input id="ReturnedDate" type="date" max="2099-12-31" min="2015-01-01" value="@String.Format("{0:yyyy-MM-dd}",pdate)" name="ReturnedDate" class="form-control ReturnedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
                                            else
                                            {
                                                <input id="ReturnedDate" type="date" max="2099-12-31" min="2015-01-01" name="ReturnedDate" class="form-control ReturnedDate" />
                                                <div class="invalid-feedback">
                                                    Please Select Date !!
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <input id="ReturnedDate" type="date" max="2099-12-31" min="2015-01-01" name="ReturnedDate" class="form-control ReturnedDate" />
                                            <div class="invalid-feedback">
                                                Please Select Date !!
                                            </div>
                                        }

                                    </div>

                                </div>
                                <div class="row">

                                    <div class="col-md-2 mb-2">
                                        <label for="StatusTypeID">Book Status<span class="text-danger">*</span></label>
                                        @Html.DropDownList("StatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  StatusTypeID", @data_val = "true", @required = "required", @id = "StatusTypeID", @style = "width:50%;" })
                                        <div class="invalid-feedback">
                                            Please Select Book Status !!
                                        </div>
                                    </div>
                                    <div class="col-md-2 mb-2">
                                        <label for="BkVfcnStatusTypeID"> Verification Status<span class="text-danger">*</span></label>
                                        @Html.DropDownList("BkVfcnStatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  BkVfcnStatusTypeID", @data_val = "true", @required = "required", @id = "BkVfcnStatusTypeID", @style = "width:50%;" })
                                        <div class="invalid-feedback">
                                            Please Select Verification Status !!
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 Attachmentdiv" id="Attachmentdiv" style="display:none;">
                                    <div class="">

                                        <div class="panel-body">
                                            <span class="panel-title"><strong>Attachments</strong></span>


                                            <div class="col-lg-8">
                                                <input type="hidden" name="hiddentrandid" id="hiddentrandid" value="@ViewBag.hiddentrandid" />
                                                <div class="col-lg-12"><input type="file" name="filesupload" id="filesupload" value="" class="pull-left btn btn-success" multiple="multiple" />    <input type="submit" value="Upload BookVerification Proof related Documents" title="Upload" class="pull-left btn btn-danger" disabled style="padding:6px;" /><br /></div>

                                            </div>


                                            <div>
                                                @if (ViewBag.BookVerificationFiles != null && ViewBag.BookVerificationFiles != "")
                                                {
                                                    foreach (var fName in ViewBag.BookVerificationFiles)
                                                    {

                                                        var name = fName;
                                                        var link = @Url.Content("~/BookVerificationFiles/" + ViewBag.hiddentrandid + "/") + name.Replace(" ", "%20");

                                                        var del_link = @Url.Content("~/TransactionBookVerification/FilesDelete?id=" + ViewBag.hiddentrandid) + ";" + name.Replace(" ", "%20");


                                                        <div class="col-lg-2">
                                                            @if (fName.EndsWith("pdf"))
                                                            {
                                                                <a href="@link" target="_blank" data-dismiss="modal">   <img src="~/Content/themes/base/images/pdf-icon.png" class="img-responsive  img-rounded img-thumbnail" style="height:50px;width:25%;margin-top:10px;" />&nbsp;&nbsp;@fName </a>

                                                            }
                                                            else if (fName.EndsWith("doc") || fName.EndsWith("docx"))
                                                            {
                                                                <a href="@link" target="_blank" data-dismiss="modal">   <img src="~/Content/themes/base/images/doc%20icon.jpg" class="img-responsive  img-rounded img-thumbnail" style="height:50px;width:25%;margin-top:10px;" />  &nbsp;&nbsp; @fName</a>

                                                            }

                                                            else
                                                            {
                                                                <a href="@link" target="_blank" data-dismiss="modal">   <img src="@link" class="img-responsive  img-rounded img-thumbnail" style="height:100px;width:100%;margin-top:10px;" /> @fName</a>
                                                            }
                                                            <a href="@del_link" class="btn  btn-lg btn-lg center-block"><i class="fa fa-trash-o color3" style="color:red"></i></a>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="col-md-6">
                                            <div class="col-md-4">

                                                <hr />


                                                <div id="imgPreview" class="thumbnail" style="display:none">
                                                    <img class="img-responsive" id="targetImg" src="@ViewBag.imgsrc" />
                                                    <div class="caption">
                                                        <a href="@ViewBag.delteimgsrc" onclick="ClearPreview()"><i class="glyphicon glyphicon-trash"></i></a>
                                                        <span id="description"></span>
                                                    </div>
                                                    @*<a href="#" class="btn btn-default" onclick="Uploadimage()">Upload</a>*@
                                                </div>

                                            </div>
                                            @*<div class="col-md-4 thumbnail" id="uploadedImage">
                                                </div>*@
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12 mb-12">
                                    <label for="Remarks">Remarks </label>


                                    @if (Model != null)
                                    {

                                        <input type="text" id="Remarks" name="Remarks" value="@Model.tranbookvfcnlst[0].Remarks" maxlength="50" class="form-control Remarks" />
                                    }
                                    else
                                    {
                                        <input type="text" id="Remarks" name="Remarks" maxlength="50" class="form-control Remarks" />
                                    }

                                </div>

                                <div class="row col-12">
                                    <h2> Book Entry Details</h2>
                                    <table class='table table-striped table-bordered bootstrap-datatable' id="tblBookVerificationList">
                                        <thead>
                                            <tr>
                                                <th><label>Book Number</label></th>
                                                <th><label>Verification Generated Date</label></th>
                                                <th><label>Old Collection Receipt Ref</label></th>
                                                <th><label>Old Collection Receipt Amt.</label></th>
                                                <th><label>Book Amount</label></th>
                                                <th><label>Verification Finding</label></th>
                                                <th><label>Verification Status</label></th>
                                                <th><label>Book Status</label></th>
                                                <th>Edit / Delete</th>

                                            </tr>
                                        </thead>
                                        <tbody class="BooksVerificationList_BODY" id="BooksVerificationListDETAIL_BODY">
                                            @if (Model != null)
                                            {
                                                var order = 0;
                                                foreach (pr_Get_Book_Verification_Entry_Details_Result details in Model.tranbookentrylst)
                                                {
                                                    string bkissdate = Convert.ToString(details.BookIssuedDate);
                                                    string bktrmdate = Convert.ToString(details.BookTerminatedDate);
                                                    string bkcoldate = Convert.ToString(details.BookCollectedDate);
                                                    string bkrtndate = Convert.ToString(details.BookReturnedDate);
                                                    string bkentdt = Convert.ToString(details.BookEntryDt);
                                                    order = ++order;
                                                    <tr class="item-row">

                                                        <td class="hide">

                                                            <input id="FD_AccountBookID" type="text" readonly value="@details.BookID" name="FD_AccountBookID" class="form-control hide FD_AccountBookID" />
                                                            <input id="FD_OwnerID" type="text" readonly value="@details.SubsId" name="FD_OwnerID" class="form-control hide FD_OwnerID" />
                                                            <input id="FD_OwnerTypeID" type="text" readonly value="@details.ProdTypeId" name="FD_OwnerTypeID" class="form-control hide FD_OwnerTypeID" />
                                                            <input id="VfcnStsId" type="text" readonly value="@details.VfcnStsId" name="FD_EmployeeId" class="form-control hide FD_EmployeeId" />
                                                            <input id="FD_BVcnRemarks" type="text" readonly value="@details.BVcnRemarks" name="FD_ReviewByEmployeeId" class="form-control hide FD_ReviewByEmployeeId" />
                                                            <input id="FD_BkVfcnFindingId" type="text" readonly value="@details.BookVfcnID" name="FD_ApprovedByEmployeeId" class="form-control hide FD_ApprovedByEmployeeId" />
                                                            <input id="FD_BookStatusTypeID" type="text" readonly value="@details.BookStsId" name="FD_BookStatusTypeID" class="form-control hide FD_BookStatusTypeID" />
                                                            <input id="FD_BookIssuedDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@String.Format("{0:yyyy-MM-dd}",bkissdate)" name="FD_BookIssuedDate" class="form-control FD_BookIssuedDate" />
                                                            <input id="FD_BookTerminatedDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@String.Format("{0:yyyy-MM-dd}",bktrmdate)" name="FD_BookTerminatedDate" class="form-control FD_BookTerminatedDate" />
                                                            <input id="FD_BookCollectedDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@String.Format("{0:yyyy-MM-dd}",bkcoldate)" name="FD_BookCollectedDate" class="form-control FD_BookCollectedDate" />
                                                            <input id="FD_BookReturnedDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@String.Format("{0:yyyy-MM-dd}",bkrtndate)" name="FD_BookReturnedDate" class="form-control FD_BookReturnedDate" />
                                                            <input id="FD_BookEntryDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@String.Format("{0:yyyy-MM-dd}",bkentdt)" name="FD_BookEntryDate" class="form-control FD_BookEntryDate" />
                                                            <input id="FD_OldReceiptRefId" type="text" readonly value="@details.OldReceiptRefId" name="FD_OldReceiptRefId" class="form-control FD_OldReceiptRefId" />
                                                        </td>

                                                        <td>
                                                            <input id="FD_BookNumber" type="text" readonly value="@details.BookNumber" name="FD_BookNumber" class="form-control FD_BookNumber" />
                                                        </td>
                                                        <td>
                                                            <input id="FD_BookVfcnGeneratedDate" type="date" max="2099-12-31" min="2015-01-01" readonly value="@details.BookVfcnGeneratedDate" name="FD_BookVfcnGeneratedDate" class="form-control FD_BookVfcnGeneratedDate" />
                                                        </td>
                                                        <td>
                                                            <input id="FD_OldReceiptRefNo" type="text" readonly value="@details.OldReceiptRefNo" name="FD_OldReceiptRefNo" class="form-control FD_OldReceiptRefNo" />

                                                        </td>
                                                        <td>
                                                            <input id="FD_OldReceiptAmt" type="text" readonly value="@details.OldReceiptAmt" name="FD_OldReceiptAmt" class="form-control FD_OldReceiptAmt" />

                                                        </td>
                                                        <td>
                                                            <input id="FD_BookAmt" type="text" readonly value="@details.BookAmt" name="FD_BookAmt" class="form-control FD_BookAmt" />

                                                        </td>
                                                        <td>
                                                            <input id="FD_VfcnFindingDesc" type="text" readonly value="@details.VfcnFindingDesc" name="FD_VfcnFindingDesc" class="form-control FD_VfcnFindingDesc" />

                                                        </td>
                                                        <td>
                                                            <input id="FD_VfcnStsDesc" type="text" readonly value="@details.VfcnStsDesc" name="FD_VfcnStsDesc" class="form-control FD_VfcnStsDesc" />

                                                        </td>
                                                        <td>
                                                            <input id="FD_BookStatus" type="text" readonly value="@details.BookSts" name="FD_BookStatus" class="form-control FD_BookStatus" />

                                                        </td>

                                                        <td>
                                                            <a href="#" id="@details.BookVfcnID" class="BKVfcneditor_edit btn btn-info btn-sm"><i class="fa fa-edit"></i></a>&nbsp;<a href="#" id="@details.BookVfcnID" class="BKVfcneditor_remove btn btn-danger btn-sm"><i class="fa fa-trash"></i></a>
                                                        </td>

                                                    </tr>

                                                }
                                            }

                                        </tbody>
                                    </table>
                                </div>
                                <div class="col-md-12 hide">


                                    <div class="col-md-3 mb-3">
                                        <label for="LinkedOfficeID">Different Office<span class="text-danger">*</span></label>
                                        @Html.DropDownList("LinkedOfficeID", null, "Please select Linked Office", new { @class = "form-control select2 custom-select  LinkedOfficeID", @data_val = "true", @id = "LinkedOfficeID", @style = "width:50%;" }) @*@required = "required",*@
                                        <div class="invalid-feedback">
                                            Please Select Linked Office !!
                                        </div>
                                    </div>

                                    <div class="card-header bg-info">
                                        <h4 class="mb-0 text-white">Fund Transfer to Another Product / Account</h4><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                                    </div>
                                    <div class="row col-md-12">

                                        <div class="col-md-3 mb-3">
                                            <label for="TransferToProductID">Transfer to Product</label>
                                            @Html.DropDownList("TransferToProductID", null, "-- Select --", new { @class = "form-control select2 custom-select  TransferToProductID", @data_val = "true", @id = "TransferToProductID", @style = "width:50%;" })
                                        </div>
                                        <div class="col-md-3 mb-3">
                                            <label for="TransferToCategory">Category</label>
                                            @Html.DropDownList("TransferToCategory", null, "-- Select --", new { @class = "form-control select2 custom-select  TransferToCategory", @data_val = "true", @id = "TransferToCategory", @style = "width:50%;" })
                                        </div>
                                        <div class="col-md-3 mb-3">
                                            <label for="TransferToProductID">Subscription A/c</label>
                                            @Html.DropDownList("TransferToProductID", null, "-- Select --", new { @class = "form-control select2 custom-select  TransferToProductID", @data_val = "true", @id = "TransferToProductID", @style = "width:50%;" })
                                        </div>
                                        <div class="col-md-3 mb-3">
                                            <label for="TransferToFundAccountID">Fund A/c</label>
                                            @Html.DropDownList("TransferToFundAccountID", null, "-- Select --", new { @class = "form-control select2 custom-select  TransferToFundAccountID", @data_val = "true", @id = "TransferToFundAccountID", @style = "width:50%;" })
                                        </div>



                                    </div>


                                </div>

                                <div class="col-12">
                                    <div class="d-md-flex align-items-center mt-3">

                                        <a href="@Url.Action("Index", "TransactionBookVerification")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>

                                        <div class="ms-auto mt-3 mt-md-1 pull-right">

                                            <button id="btnsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        <script type="text/javascript">

        $(document).ready(function () {

            $('#Attachmentdiv').hide();
            if ($('#BookVerificationListID').val() == "") {
                $('#BookVerificationListID').val("0");

                 var now = new Date();

                var day = ("0" + now.getDate()).slice(-2);
                var month = ("0" + (now.getMonth() + 1)).slice(-2);

                var today = now.getFullYear() + "-" + (month) + "-" + (day);
                if ($('#GeneratedDate').val() == '')
                    $('#GeneratedDate').val(today);
                if ($('#CollectedDate').val() == '')
                    $('#CollectedDate').val(today);



            }
            else {
            //    $('#Attachmentdiv').show();
            //    //LoadSubTrnTyps();

                 //LoadProdDtls();
                //LoadBooks();
                LoadReceiptDtls();
            }

            //--------------Delete Book Entry Record----------------//
            $(document).on("click", "a.BKVfcneditor_remove", function () {

                Swal.fire({
                    title: "Are you sure?",
                    text: "Are you sure to delete this Book Verification Entry record ? ",
                    type: 'warning',
                    confirmButtonText: "Yes",
                    showCancelButton: true,
                    cancelButtonText: "No",
                    showCloseButton: true
                }).then((result) => {
                    if (result.value) {
