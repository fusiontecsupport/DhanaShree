             function LoadBooks() {

                 var prod = $("#ProductTypeID option:selected").val();
                 var subsid = $("#ProductID option:selected").val();
            var bkvfcnlstid = $(".BookVerificationListID").val();

                 if (prod > 0 && subsid > 0 ) {
                url = '@Url.Action("GetBooks", "TransactionBookVerification")/?id=' + subsid + '~' + prod + '~'+bkvfcnlstid;
                $.ajax({
                    type: 'post',
                    url: url,
                    dataType: 'json',
                    async: false,
                    success: function (data) {
                        console.log(data);
                        $("#BookID").empty().trigger('change');
                        $("#BookID").append('<option value="">Please Select Book</option>');
