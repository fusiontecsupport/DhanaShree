@model CHITERP.Models.TypeMaster

@{
    ViewBag.Title = "Type Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            @Html.Raw(ViewBag.msg)

            <div class="card">

                <div class="card-body">
                    <div class="row">
                        <div class="col-12">
                            <div class="card-header border-bottom" style="background-color:white;">
                                <div class="d-flex no-block align-items-center mb-0">
                                    <h3 class="card-title text-dark-primary"><i class="fa fa-bar-chart-o fa-fw"></i>@ViewBag.Title</h3>
                                    <div class="ms-auto">
                                        <div class="btn-group">
                                            <a class="btn btn-success btn-sm pull-right" style="padding:3px;margin:0 0 10px" href="@Url.Action("Form","TypeMaster")"><i class="fa fa-plus"></i>&nbsp; Add New </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <table id="zero_config_wrapper" class="table table-striped table-bordered dataTable" cellspacing="0" width="100%">
                            <thead class="tblhead">
                                <tr>

                                    <th>Type</th>
                                    <th>TypePriority</th>
                                    <th>ControlName</th>
                                    <th>TypeCategoryId</th>
                                    <th class="hide">ID</th>
                                    @*<th class="">Edit / Delete</th>*@
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>

                                    <th>Type</th>
                                    <th>TypePriority</th>
                                    <th>ControlName</th>
                                    <th>TypeCategoryId</th>
                                    <th class="hide">ID</th>
                                    @*<th class="">Edit / Delete</th>*@
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
    <br />

    @section Scripts {

        <script type="text/javascript" class="init">

        var editor; // use a global for the submit and return data rendering in the examples
            $(document).ready(function () {


                table = $('.dataTable').DataTable({
                    ajax: "@Url.Action("GetAjaxDetailsData", "TypeMaster")",
                    "ordering": true,
                    "order": [[0, "asc"]],
                    "language": {
                        "search": '<i class="fa fa-search"></i>',
                        "searchPlaceholder": "search",
                        "paginate": {
                            "previous": '<i class="fa fa-angle-left"></i>',
                            "next": '<i class="fa fa-angle-right"></i>'
                        }
                    },
                    columns: [
                        
                        { data: "Type" },
                        { data: "TypePriority" },
                        { data: "ControlName" },
                        { data: "TypeCategoryId" },
                        { data: "TypeId", "visible": false },
                        @*{

                            mRender: function (data, type, row) {
                                return '<a href="@Url.Action("Edit", "TypeMaster")/' + row["TypeId"] + '"   class="editor_edit btn btn-warning btn-sm" ><i class="fa fa-edit"></i></a>&nbsp;<a href="#" id="' + row["TypeId"] + '\" class="editor_remove btn btn-danger hide btn-sm" ><i class="fa fa-trash"></i></a>'
                            }
                        }*@
                    ]
                });
                $(document).on("click", "a.editor_remove", function () {

                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to delete this record ? ",
                        icon: 'warning',
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonText: "No",
                        showCloseButton: true
                    }).then((result) => {
                        if (result.value) {
                            var idx = $(this).attr('id');
                            //base = window.location.origin;
                            var baseUrl = $("#BaseUrl").data("baseurl");
                            $.post(baseUrl + "/TypeMaster/Del",
                                {
                                    id: idx, fld: "TypeMaster"
                                },
                                function (data, status) {

                                    if (data == "") {
                                        Swal.fire({
                                            position: 'center',
                                            type: 'info',
                                            title: 'You are not authorize to Delete..!',
                                            showConfirmButton: true,
                                            //timer: 5500
                                        }).then((result) => {
                                            if (result.value) {
                                                var returnurl = "@Url.Action("Index", "TypeMaster")";
                                                window.location.href = returnurl;
                                            }
                                        });
                                    }
                                    else if (data != "Deleted Successfully ...") {
                                        Swal.fire({
                                            position: 'center',
                                            type: 'success',
                                            title: data,
                                            showConfirmButton: true,
                                            //timer: 3500
                                        }).then((result) => {
                                            if (result.value) {
                                                var returnurl = "@Url.Action("Index", "TypeMaster")";
                                                window.location.href = returnurl;
                                            }
                                        });
                                    }
                                    else {
                                        Swal.fire({
                                            position: 'center',
                                            type: 'success',
                                            title: 'Type Master Details Deleted Successfully ..!', //You are not authorize to Delete..!',
                                            showConfirmButton: true,
                                            //timer: 3500
                                        }).then((result) => {
                                            if (result.value) {
                                                var returnurl = "@Url.Action("Index", "TypeMaster")";
                                                window.location.href = returnurl;
                                            }
                                        });
                                    }

                                });
                        }
                        else if (result.dismiss === 'cancel') { return false; }
                    });


                });
            });
            
        </script>
        }
        