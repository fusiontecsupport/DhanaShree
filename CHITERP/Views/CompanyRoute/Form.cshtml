        function checkemail(email) {
            //alert(email);
            if (email != "") {
                //var regex = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;
                var regex = /^([\w-\.]+)@@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$/;
                if (!regex.test(email)) {
                    Swal.fire({
                        text: 'Please Enter Valid e MailId',
                        type: 'warning',
                        //timer: 2500,
                        showConfirmButton: true
                    }).then(function () {
                        $('.CPEMAILID').focus();
                    });
                }
            }
        }

    </script>

}

