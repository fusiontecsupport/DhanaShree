@{
    ViewBag.Title = "Route Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            @Html.Raw(ViewBag.msg)

            <div class="card">

                <div class="card-body">
                    <div class="row">
                        <div class="col-12">
                            <div class="card-header border-bottom" style="background-color:white;">
                                <div class="d-flex no-block align-items-center mb-0">
                                    <h3 class="card-title text-dark-primary"><i class="fa fa-bar-chart-o fa-fw"></i>@ViewBag.Title</h3>
                                    <div class="ms-auto">
                                        <div class="btn-group">
                                            <a class="btn btn-success btn-sm pull-right" style="padding:3px;margin:0 0 10px" href="@Url.Action("NForm", "CompanyRoute")"><i class="fa fa-plus"></i>&nbsp; Add New </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />

                            <table id="zero_config_wrapper" class="table table-striped table-bordered dataTable" cellspacing="0" width="100%">
                                <thead class="tblhead">
                                    <tr>
                                        <th>Code</th>
                                        <th>Name</th>
                                        <th>Status</th>
                                        <th class="hide">ID</th>
                                        <th class="">Edit / Delete</th>
                                    </tr>
                                </thead>
                                <tfoot>
                                    <tr>
                                        <th>Code</th>
                                        <th>Name</th>
                                        <th>Status</th>
                                        <th class="hide">ID</th>
                                        <th class="">Edit / Delete</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

