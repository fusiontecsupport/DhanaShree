                                        icon: 'success',
                                        title: data, //You are not authorize to Delete..!',
                                        showConfirmButton: true,
                                        //timer: 3500
                                    }).then((result) => {
                                        if (result.value) {
                                            var returnurl = "@Url.Action("Index", "CompanyRoute")";
                                            window.location.href = returnurl;
                                        }
                                    });
                                }

                            });


                    } else if (result.dismiss === 'cancel') {


                        return false;

                    }
                });

