                                        showConfirmButton: true,
                                        //timer: 5500
                                    }).then((result) => {
                                        if (result.value) {
                                            var returnurl = "@Url.Action("Index", "CompanyRoute")";
                                            window.location.href = returnurl;
                                        }
                                    });
                                }
                                else {
