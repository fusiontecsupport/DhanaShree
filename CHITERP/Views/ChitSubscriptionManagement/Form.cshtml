        function ValidateMyform(form, event) {
            flag = true;
            i = 0;
            var frmflag = $(form).attr('data-flag');
            //alert(frmflag);
            var form = document.getElementById('ChitSubscriptionManagementform');
            var clientid = $(".FPersonID").val();
            if (clientid == "" || clientid == null) {
                Swal.fire({
                    title: "Client Selected?!",
                    text: "Please Select Client!!",
                    type: "error",
                    position: "Center"
                });
                flag = false;

            }

            var form = document.getElementById('ChitSubscriptionMainform');
            var inputs = form.getElementsByTagName('input');
            var forms = document.getElementsByClassName('needs-validation');

            if (form.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
                flag = false;
            }
            else {
                form.classList.add('was-validated'); flag = true;
            }

            var balmemberscnt = $(".BalanceMembersAvailable").val();
            var chitsubsid = $(".SubscriptionID").val();

            if (balmemberscnt <= 0 && (chitsubsid == "" || chitsubsid=="0")) {
                Swal.fire({
                    title: "Check Members Count?!",
                    text: "Members already alotted or Maximum members not defined!!",
                    type: "error",
                    position: "Center"
                });
                flag = false;
            }
            if (clientid == "" || clientid == null) {
                Swal.fire({
                    title: "Check Client Selected?!",
                    text: "Please Select Client!!",
                    type: "error",
                    position: "Center"
                });
                flag = false;

            }

            if (flag) {
                if (frmflag == 0) {
                    event.preventDefault(); //to prevent submitting


                    Swal.fire({
                        title: "Are you sure?",
                        text: "Are you sure to Submit the Information !",
                        type: "warning",
                        confirmButtonText: "Yes",
                        showCancelButton: true,
                        cancelButtonColor: "#d43f3a",
                        cancelButtonText: "No",
                        showCloseButton: true,
                        //position: "Center",
                    }).then((result) => {
                        if (result.value) {
                            flag = true;
                            var ActionName = "SaveData";
                            var controllername = "ChitSubscriptionManagement";
                            var pagetitle = "@ViewBag.Title";
                            var formData = $('#ChitSubscriptionMainform').serialize();
                            submitFormData(ActionName, controllername, pagetitle, formData);

                        }
                        else if (result.isDenied) {
                            Swal.fire('Changes are not saved', '', 'info')
                            flag = false;
                            return false;
                        }
                    });
                }
            }
            else {
                return false;
            }
        }

