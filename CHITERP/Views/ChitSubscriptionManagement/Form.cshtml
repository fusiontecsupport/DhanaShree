@using CHITERP.Models;
@using CHITERP.Data;
@model CHITERP.Models.ChitTransSS

@{
    ViewBag.Title = "Chit Subscription";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .spacer5 {
        height: 15px;
    }
    /*   body {
        font-family: Arial !important;
    }*/
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">

                <div class="card-header bg-info">
                    <h4 class="mb-0 text-white">@ViewBag.Title </h4><a class="mb-0 text-white" style="margin-top:10px !important"></a>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6 col-lg-6">


                            <div class="mb-6 row">
                                <label class="col-sm-6 text-end control-label col-form-label">Organization/Person</label>
                                <div class="col-sm-6">
                                    @Html.DropDownList("FPersonID", null, "Please Select Organization/Person", new
                                    {
                                        @class = "form-control select2 custom-select  FPersonID",
                                        @data_val = "true",
                                        @required = "required",
                                        @id = "FPersonID",
                                        @onchange = "ClientNameChange();"@*, @style = "width:50%;"*@})
                                    <div class="invalid-feedback">
                                        Please Select Organization/Person !!
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-6">
                            <div class="mb-3 row">
                                <label class="col-sm-3 text-end control-label col-form-label">Introduced By	</label>
                                <div class="col-sm-6">
                                    <input type="text" readonly id="IntroducedBy" class="form-control IntroducedBy" name="IntroducedBy" />
                                </div>
                            </div>
                        </div>

                    </div>

                    <div id="mytab">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" id="Subscriptions">
                                <a class="nav-link d-flex active tab" data-bs-toggle="tab" href="#Subscription" role="tab" aria-selected="true">
                                    <span>
                                        <i class="fa fa-rocket"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Subscription</span>
                                </a>
                            </li>
                            <li class="nav-item " id="CollectionSchedule">
                                <a class="nav-link d-flex tab1" data-bs-toggle="tab" href="#ChitCollectionSchedule" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-book"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">
                                        Collection Schedule & Receipts
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item" id="CQRCode">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#ChitQRCode" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-qrcode"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">QRCode</span>
                                </a>
                            </li>
                            <li class="nav-item hide" id="Addresses">
                                <a class="nav-link d-flex tab1" data-bs-toggle="tab" href="#Address" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-building"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">
                                        Address
                                    </span>
                                </a>
                            </li>

                            <li class="nav-item hide" id="Contact1">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#Contacts" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-phone"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Contacts</span>
                                </a>
                            </li>

                            <li class="nav-item hide" id="Closure1">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#Closure" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-users"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Closure</span>
                                </a>
                            </li>

                            <li class="nav-item hide" id="Collection1">
                                <a class="nav-link d-flex tab2" data-bs-toggle="tab" href="#Collection" role="tab" aria-selected="false">
                                    <span>
                                        <i class="fa fa-list-alt"></i>
                                    </span>
                                    <span class="d-none d-md-block ms-2">Collection</span>
                                </a>
                            </li>
                        </ul>


                        <div class="tab-content">
                            <div class="tab-pane active" id="Subscription" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <br />
                                        <form action="@Url.Content("~/ChitGroupManagement/Savedata")" method="post" data-flag="0" class="needs-validation ChitSubscriptionMainform" id="ChitSubscriptionMainform" name="ChitSubscriptionMainform" novalidate onsubmit="return ValidateMyform(this,event);">

                                            <div class="row">

                                                <div class="col-md-2 mb-2 hide">
                                                    <label for="SubscriptionID">Id</label>
                                                    @if (Model != null)
                                                    {
                                                        <input type="text" id="SubscriptionID" name="SubscriptionID" value="@Model.chitsubs[0].SubscriptionID" class="form-control SubscriptionID" />
                                                        <input type="text" id="PersonID" name="PersonID" value="@Model.chitsubs[0].PersonID" class="form-control PersonID" />
                                                    }
                                                    else
                                                    {
                                                        <input type="text" id="SubscriptionID" name="SubscriptionID" value="0" class="form-control SubscriptionID" />
                                                        <input type="text" id="PersonID" name="PersonID" value="" class="form-control PersonID" />
                                                    }
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="ChitSchemeID">Chit Scheme <span class="text-danger">*</span></label>

                                                    @Html.DropDownList("ChitSchemeID", null, "Please select", new
                                                    {
                                                        @class = "form-control select2 custom-select  ChitSchemeID",
                                                        @data_val = "true",
                                                        @required = "required",
                                                        @id = "ChitSchemeID",
                                                        @onchange = "SchemeNameChange();"@*, @style = "width:50%;"*@})
                                                    <div class="invalid-feedback">
                                                        Please Select Scheme Code !!
                                                    </div>

                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="SchemeName">Scheme Name</label>
                                                    <input type="text" id="SchemeName" name="SchemeName" class="form-control SchemeName" readonly maxlength="150" tabindex="2" />
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="ChitValue">Chit Value (₹)</label>
                                                    <input type="text" id="ChitValue" name="ChitValue" class="form-control ChitValue" readonly maxlength="150" tabindex="2" />
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="ChitDuration">Duration</label>
                                                    <input type="text" id="ChitDuration" name="ChitDuration" class="form-control ChitDuration" readonly maxlength="150" tabindex="2" />
                                                </div>

                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-3 mb-3">
                                                    <label for="ChitGroupID">Group <span class="text-danger">*</span></label>
                                                    <input type="text" id="edChitGroupID" name="edChitGroupID" class="form-control hide edChitGroupID" value="@ViewBag.edChitGroupID" readonly maxlength="150" tabindex="2" />
                                                    @Html.DropDownList("ChitGroupID", null, "Please select", new { @class = "form-control select2 custom-select  ChitGroupID", @data_val = "true", @required = "required", @id = "ChitGroupID", @style = "width:50%;", @onchange = "GetMemberDtl();" })
                                                    <div class="invalid-feedback">
                                                        Please Select Group !!
                                                    </div>
                                                </div>
                                                <div class="col-md-3 mb-3">
                                                    <label for="GroupTypeID">Group Type</label>
                                                    <input type="text" id="PrevGroupTypeID" name="PrevGroupTypeID" class="form-control hide PrevGroupTypeID" value="@ViewBag.PrevGroupTypeID" readonly maxlength="150" tabindex="2" />
                                                    <input type="text" id="GroupTypeID" name="GroupTypeID" class="form-control hide GroupTypeID" readonly maxlength="150" tabindex="2" />
                                                    <input type="text" id="GroupTypeDesc" name="GroupTypeDesc" class="form-control GroupTypeDesc" readonly maxlength="150" tabindex="2" />
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="AlreadyJoined">Already Joined</label>
                                                    <input type="text" id="AlreadyJoined" name="AlreadyJoined" class="form-control AlreadyJoined" readonly maxlength="150" tabindex="2" />
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="BalanceMembersAvailable">Balance Members Available</label>
                                                    <input type="text" id="BalanceMembersAvailable" name="BalanceMembersAvailable" class="form-control BalanceMembersAvailable" readonly maxlength="150" tabindex="2" />
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="TotalGroupMembers">Total Group Members</label>
                                                    <input type="text" id="TotalGroupMembers" name="TotalGroupMembers" class="form-control TotalGroupMembers" readonly maxlength="150" tabindex="2" />
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">

                                                <div class="col-md-3 mb-3">
                                                    <label for="CollectionTypeID">Collection Type<span class="text-danger">*</span></label>

                                                    @Html.DropDownList("CollectionTypeID", null, "Please select", new { @class = "form-control select2 custom-select  CollectionTypeID", @data_val = "true", @required = "required", @id = "CollectionTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Collection Type !!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="CollectionIntervalTypeID"> Collection Interval<span class="text-danger">*</span></label>

                                                    @Html.DropDownList("CollectionIntervalTypeID", null, "Please select", new { @class = "form-control select2 custom-select  CollectionIntervalTypeID", @data_val = "true", @required = "required", @id = "CollectionIntervalTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Interval !!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="FundAccountID">Fund Account</label>

                                                    @Html.DropDownList("FundAccountID", null, "Please select", new { @class = "form-control select2 custom-select  FundAccountID", @data_val = "true", @id = "FundAccountID", @style = "width:50%;" })

                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label for="LinkedOfficeID">Linked Office<span class="text-danger">*</span></label>

                                                    @Html.DropDownList("LinkedOfficeID", null, "Please select", new { @class = "form-control select2 custom-select  LinkedOfficeID", @data_val = "true", @required = "required", @id = "LinkedOfficeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Linked Office !!
                                                    </div>
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-3 mb-3">
                                                    <label for="BookPickupDay">Book Pickup Day<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("BookPickupDay", null, "Select Pickup Date", new { @class = "form-control select2 custom-select  BookPickupDay", @data_val = "true", @required = "required", @id = "BookPickupDay", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Book  Pickup Date !!
                                                    </div>
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label>Route <span class="text-danger">*</span> </label>
                                                    @Html.DropDownList("RouteID", null, "Please select", new { @class = "form-control select2 custom-select  RouteID", @data_val = "true", @id = "RouteID", @style = "width:50%;", @required="required" })
                                                    <div class="invalid-feedback">
                                                        Please Select Route !!
                                                    </div>
                                                </div>



                                                <div class="col-md-2 mb-2">
                                                    <label for="ChitSchemeID">No of. Tickets</label>
                                                    @if (Model != null)
                                                    {
                                                        <input type="number" id="TicketNumber" min="0" name="TicketNumber" value="@Model.chitsubs[0].TicketNumber" class="form-control TicketNumber" maxlength="50" />
                                                        <div class="invalid-feedback">
                                                            Please Enter No. of Tickets!!
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="number" id="TicketNumber" min="0" name="TicketNumber" value="" class="form-control TicketNumber" maxlength="50" />
                                                        <div class="invalid-feedback">
                                                            Please Enter  No. of Tickets!!
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label>Mode <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("CollectionModeTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  CollectionModeTypeID", @data_val = "true", @required = "required", @id = "CollectionModeTypeID", @style = "width:50%;" })

                                                    <div class="invalid-feedback">
                                                        Please Select Mode !!
                                                    </div>
                                                </div>

                                            </div>
                                            <br />
                                            <div class="row">

                                                <div class="col-md-3 mb-3">

                                                    <label>Collection Agent 1<span class="text-danger">*</span></label>
                                                    @Html.DropDownList("CollectionAgentPersonID1", null, "Please select Collection Employee 1", new { @class = "form-control select2 custom-select  CollectionAgentPersonID1", @data_val = "true", @required = "required", @id = "CollectionAgentPersonID1", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Collection Employee 1!!
                                                    </div>
                                                </div>
                                                <div class="col-md-3 mb-3">

                                                    <label>Alternate Collection Agent </label>
                                                    @Html.DropDownList("CollectionAgentPersonID2", null, "Please select Collection Employee 2", new { @class = "form-control select2 custom-select  CollectionAgentPersonID2", @data_val = "true", @id = "CollectionAgentPersonID2", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Collection Employee 2!!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3">

                                                    <label>Commission Agent 1 <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("CommisionAgentPersonID", null, "Please select Commission Employee", new { @class = "form-control select2 custom-select  CommisionAgentPersonID", @data_val = "true", @required = "required", @id = "CommisionAgentPersonID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Commission Agent 1!!
                                                    </div>
                                                </div>

                                                <div class="col-md-3 mb-3">

                                                    <label>Commission Agent 2</label>
                                                    @Html.DropDownList("CommisionAgentPersonID2", null, "Please select Commission Employee", new { @class = "form-control select2 custom-select  CommisionAgentPersonID2", @data_val = "true", @id = "CommisionAgentPersonID2", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Commission Agent 2!!
                                                    </div>
                                                </div>
                                            </div>
                                            <br />
                                            <div class="row">
                                                <div class="col-md-2 mb-2">
                                                    <label for="CommencementDate">Commencement Date</label>
                                                    @if (Model != null)
                                                    {
                                                        string pdatetime = Convert.ToString(Model.chitsubs[0].CommencementDate);
                                                        if ((pdatetime != null && pdatetime != ""))
                                                        {
                                                            var param = pdatetime.Split(' ');
                                                            DateTime pdate = Convert.ToDateTime(param[0]).Date;
                                                            <input id="CommencementDate" onchange="CalcEndDt();" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",pdate)" name="CommencementDate" class="form-control CommencementDate" />
                                                        }
                                                        else
                                                        {
                                                            <input id="CommencementDate" onchange="CalcEndDt();" type="date" max="2099-12-31" name="CommencementDate" class="form-control  CommencementDate" />
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <input id="CommencementDate" onchange="CalcEndDt();" type="date" max="2099-12-31" name="CommencementDate" class="form-control CommencementDate" />
                                                    }
                                                    <div class="invalid-feedback">
                                                        Please Select Commencement Date !!
                                                    </div>
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="CommencementTime">Commencement Time</label>
                                                    @if (Model != null)
                                                    {
                                                        string pdatetime = Convert.ToString(Model.chitsubs[0].CommencementDate);
                                                        if ((pdatetime != null && pdatetime != ""))
                                                        {
                                                            var param = pdatetime.Split(' ');
                                                            string ptime = param[1];
                                                            <input type="time" min="00:00" max="23:00" id="CommencementTime" value="@ptime" name="CommencementTime" class="form-control CommencementTime" />

                                                        }
                                                        else
                                                        {
                                                            <input type="time" min="00:00" max="23:00" id="CommencementTime" name="CommencementTime" class="form-control CommencementTime" />
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <input type="time" min="00:00" max="23:00" id="CommencementTime" name="CommencementTime" class="form-control CommencementTime" />
                                                    }
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="StartDate">Collection Start Date</label>
                                                    @if (Model != null)
                                                    {
                                                        string pdatetime = Convert.ToString(Model.chitsubs[0].StartDate);
                                                        if ((pdatetime != null && pdatetime != ""))
                                                        {
                                                            var param = pdatetime.Split(' ');
                                                            DateTime pdate = Convert.ToDateTime(param[0]).Date;
                                                            <input id="StartDate" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",pdate)" name="StartDate" class="form-control StartDate" onchange="CalcEndDt();" required />
                                                            <div class="invalid-feedback">
                                                                Please Select Collection Start Date !!
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <input id="StartDate" type="date" max="2099-12-31" name="StartDate" class="form-control StartDate" onchange="CalcEndDt();" />
                                                            <div class="invalid-feedback">
                                                                Please Select Collection Start Date !!
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <input id="StartDate" type="date" max="2099-12-31" name="StartDate" class="form-control StartDate" onchange="CalcEndDt();" />
                                                        <div class="invalid-feedback">
                                                            Please Select Collection Start Date !!
                                                        </div>
                                                    }
                                                </div>

                                                <div class="col-md-2 mb-2">
                                                    <label for="EndDate">Closure Date</label>
                                                    @if (Model != null)
                                                    {
                                                        string pdatetime = Convert.ToString(Model.chitsubs[0].EndDate);
                                                        if ((pdatetime != null && pdatetime != ""))
                                                        {
                                                            var param = pdatetime.Split(' ');
                                                            DateTime pdate = Convert.ToDateTime(param[0]).Date;
                                                            <input id="EndDate" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",pdate)" name="EndDate" class="form-control EndDate" />
                                                            <div class="invalid-feedback">
                                                                Please Select Closure Date !!
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <input id="EndDate" type="date" max="2099-12-31" name="EndDate" class="form-control EndDate" />
                                                            <div class="invalid-feedback">
                                                                Please Select Closure Date !!
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <input id="EndDate" type="date" max="2099-12-31" name="EndDate" class="form-control EndDate" />
                                                        <div class="invalid-feedback">
                                                            Please Select Closure Date !!
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label>Status <span class="text-danger">*</span></label>
                                                    @Html.DropDownList("StatusTypeID", null, "Please select Status", new { @class = "form-control select2 custom-select  StatusTypeID", @data_val = "true", @required = "required", @id = "StatusTypeID", @style = "width:50%;" })
                                                    <div class="invalid-feedback">
                                                        Please Select Status
                                                    </div>
                                                </div>
                                                <div class="col-md-2 mb-2">
                                                    <label for="TicketPaidNumber">Ticket Paid#</label>
                                                    @if (Model != null)
                                                    {
                                                        <input type="number" min="0" id="TicketPaidNumber" name="TicketPaidNumber" value="@Model.chitsubs[0].TicketPaidNumber" class="form-control TicketPaidNumber" />
                                                    }
                                                    else
                                                    {
                                                        <input type="number" min="0" id="TicketPaidNumber" name="TicketPaidNumber" value="" class="form-control TicketPaidNumber" readonly />
                                                    }

                                                </div>

                                            </div>
                                            <div class="col-12">
                                                <div class="d-md-flex align-items-center mt-3">
                                                    <a href="@Url.Action("Index", "ChitSubscriptionManagement")" class="btn btn-danger rounded-pill px-4 pull-left" tabindex="5">Go Back</a>
                                                    <div class="ms-auto mt-3 mt-md-1 pull-right">
                                                        <button id="btnsave" type="submit" class="btn btn-info font-weight-medium rounded-pill px-4" tabindex="4">Submit</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane p-3" id="ChitCollectionSchedule" role="tabpanel">
                                <div class="col-md-12">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-lg-3 hide">
                                                    <div class="form-group">
                                                        <label>primary</label>
                                                        <input class="form-control" id="ChitSchemeID" value="@ViewBag.ChitSchemeID" name="ChitSchemeID" />
                                                    </div>
                                                </div>
                                                <input type="text" id="CHITSCHEDULEDETAILIDX" value="0" name="CHITSCHEDULEDETAILIDX" class="CHITSCHEDULEDETAILIDX hide" />
                                                <table class='table table-striped table-bordered bootstrap-datatable' id="CHITSCHEDULEDETAIL">
                                                    <thead>
                                                        <tr>
                                                            <th colspan="6"><h4>Planned</h4></th>
                                                            <th colspan="4"><h4>Actuals</h4></th>

                                                        </tr>
                                                        <tr>
                                                            <th><label>Inst. No</label></th>
                                                            <th><label>Inst. Date</label></th>
                                                            <th><label>Subs. Amt</label></th>
                                                            <th><label>Div. Amt</label></th>
                                                            <th><label>Due. Amt</label></th>
                                                            <th><label>Balance Due Amt</label></th>

                                                            <th><label>Colln. Date</label></th>
                                                            <th><label>Colln. Amt</label></th>
                                                            <th><label>Bal. Actuals</label></th>
                                                            <th><label>Colln. Sts</label></th>

                                                        </tr>
                                                    </thead>
                                                    <tbody class="CHITSCHEDULEDETAIL_BODY" id="CHITSCHEDULEDETAIL_BODY">
                                                        @if (Model != null)
                                                        {
                                                            var order = 0;
                                                            foreach (pr_Get_Chit_Collection_Pattern_n_Actuals_Details_Result details in Model.chitschedules)
                                                            {
                                                                order = ++order;
                                                                <tr class="item-row">

                                                                    <td>

                                                                        <input id="InstNo" type="number" style="width:60px;" readonly value="@details.InstNo" name="InstNo" class="form-control InstNo" required />
                                                                    </td>
                                                                    <td>

                                                                        <input id="InsttDt" readonly style="width:95px;" type="text" value="@details.InsttDt" name="InsttDt" class="form-control DtlDueAmt" />
