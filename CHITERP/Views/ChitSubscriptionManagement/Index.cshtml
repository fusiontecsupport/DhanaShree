@{
    ViewBag.Title = "Regular - Chit Subscription Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            @Html.Raw(ViewBag.msg)

            <div class="card">

                <div class="card-body">
                    <div class="row">
                        <div class="col-12">
                            <div class="card-header border-bottom" style="background-color:white;">
                                <div class="d-flex no-block align-items-center mb-0">
                                    <h3 class="card-title text-dark-primary"><i class="fa fa-bar-chart-o fa-fw"></i>@ViewBag.Title</h3>
                                    <div class="ms-auto">
                                        <div class="btn-group">
                                            <a class="btn btn-success btn-sm pull-right" style="padding:3px;margin:0 0 10px" href="@Url.Action("Form", "ChitSubscriptionManagement")"><i class="fa fa-plus"></i>&nbsp; Add New </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="col-lg-12" style="margin-top:10px">

                                <form action="#" method="post" accept-charset="utf-8" id="ChitSubscriptionFilterform" data-ng-controller="ChitSubscription" name="ChitSubscriptionFilterform">
                                    <div class="row">
                                        <div class="col-md-2 mb-2">
                                            <label for="from">From Date</label>

                                            <input id="from" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",System.Web.HttpContext.Current.Session["SDATE"])" required name="from" class="form-control from" />
                                            <div class="invalid-feedback">
                                                Please Select From Date !!
                                            </div>
                                        </div>
                                        <div class="col-md-2 mb-2">
                                            <label for="from">To Date</label>

                                            <input id="to" type="date" max="2099-12-31" value="@String.Format("{0:yyyy-MM-dd}",System.Web.HttpContext.Current.Session["EDATE"])" required name="to" class="form-control to" />
                                            <div class="invalid-feedback">
                                                Please Select To Date !!
                                            </div>
                                        </div>
                                        <div class="col-md-3 mb-3">

                                            <label>Collection Agent <span class="text-danger">*</span></label>
                                            @Html.DropDownList("CollectionAgentPersonID", null, "Please select Collection Employee ", new { @class = "form-control select2 custom-select  CollectionAgentPersonID", @data_val = "true", @required = "required", @id = "CollectionAgentPersonID", @style = "width:50%;" })
                                            <div class="invalid-feedback">
                                                Please Select Collection Employee !!
                                            </div>
                                        </div>
                                        <div class="col-md-2 mb-2">
                                            <br />
                                            <input type="submit" name="submit" value="Search" class="btn btn-info btn-sm" />
                                        </div>
                                    </div>
                                </form>

                            </div>
                            <br />

                            <table id="zero_config_wrapper" class="table table-striped table-bordered dataTable" cellspacing="0" width="100%">
                                <thead class="tblhead">
                                    <tr>

                                        <th>S.Date</th>
                                        <th>Subscription Code</th>
                                        <th>Client Name</th>

                                        <th>Chit Value (₹)</th>
                                        <th>Client Mobile</th>
                                        @*<th>Collection Interval</th>*@
                                        <th>Collection Agent</th>

                                        <th>Status</th>
                                        <th class="hide">ID</th>
                                        <th class="">Edit / Delete</th>
                                    </tr>
                                </thead>
                                <tfoot>
                                    <tr>

                                        <th>S.Date</th>
                                        <th>Subscription Code</th>
                                        <th>Client Name</th>
                                        <th>Chit Value (₹)</th>
                                        <th>Client Mobile</th>
                                        @*<th>Collection Interval</th>*@
                                        <th>Collection Agent</th>
                                        <th>Status</th>
                                        <th class="hide">ID</th>
                                        <th class="">Edit / Delete</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {

    <script type="text/javascript" class="init">

        var editor; // use a global for the submit and return data rendering in the examples
        $(document).ready(function () {

            table = $('.dataTable').DataTable({
                ajax: "@Url.Action("GetAjaxData", "ChitSubscriptionManagement")",
                "ordering": true,
                dom: 'Blfrtip',
                buttons: [
                    "excel",
                    "pdf",
                    /*{ extent: "print", text: "<span class='glyphicon glyphicon-print'></span> Print" },*/
                    //{ extent: "excelHtml5", text: "<span class='glyphicon glyphicon-th-list'></span> Excel HTML5 Export" },
                    //{ extent: "pdfHtml5", text: "<span class='glyphicon glyphicon-save'></span> PDF HTML5 Export", title: "Filename" }
                ],
                "order": [[0, "desc"]],
                "language": {
                    "search": '<i class="fa fa-search"></i>',
                    "searchPlaceholder": "search",
                    "paginate": {
                        "previous": '<i class="fa fa-angle-left"></i>',
                        "next": '<i class="fa fa-angle-right"></i>'
                    }
                },
                columns: [
                    { data: "SubsDate" },
                    { data: "SubscriptionCode" },
                    { data: "ClientName" },
                    { data: "ChitValue" },
                  /*  { data: "IntervalFreqTypeDesc" },*/
                    { data: "ClientContactNos" },
                    { data: "CollectionAgent" },
                    { data: "StatusTypeDesc" },

                    { data: "SubsctiptionID", "visible": false },
                    {

                        mRender: function (data, type, row) {
                            return '<a href="@Url.Action("Edit", "ChitSubscriptionManagement")/' + row["SubsctiptionID"] + '"   class="editor_edit btn btn-warning btn-sm" ><i class="fa fa-edit"></i></a>&nbsp;<a href="#" id="' + row["SubsctiptionID"] + '\" class="editor_remove btn btn-danger btn-sm" ><i class="fa fa-trash"></i></a>' +
                                '&nbsp;<a href="@Url.Action("Form", "ChitDividendPayment")/' + row["SubsctiptionID"] + '"  title="Dividend" class="editor_edit btn btn-info btn-sm" ><i class="fa fa-edit"></i></a>&nbsp;'+
                            '&nbsp;<a href="@Url.Action("ChitLedgerRpt", "ChitSubscriptionManagement")/?id='+ row["SubsctiptionID"] + '\" class="btn btn-info btn-sm" target="_blank"><i class="fa fa-print"></i></a>'
                        }
                    }
                ]
            });

            //          alert("4");
            //--------------Delete Record----------------//
            $(document).on("click", "a.editor_remove", function () {

                Swal.fire({
                    title: "Are you sure?",
                    text: "Are you sure to delete this record ? ",
                    icon: 'warning',
                    confirmButtonText: "Yes",
                    showCancelButton: true,
                    cancelButtonText: "No",
                    showCloseButton: true
                }).then((result) => {
                    if (result.value) {
                        var idx = $(this).attr('id');
                        //base = window.location.origin;
                        var baseUrl = $("#BaseUrl").data("baseurl");
                        $.post(baseUrl + "/ChitSubscriptionManagement/Del",
                            {
                                id: idx, fld: "ChitSubscription"
                            },
                            function (data, status) {

                                if (data == "Deleted Successfully ...") {
                                    Swal.fire({
                                        position: 'center',
                                        type: 'success',
                                        title: 'Chit Subscription Details Deleted Successfully ..!', //You are not authorize to Delete..!',
                                        showConfirmButton: true,
                                        //timer: 3500
                                    }).then((result) => {
                                        if (result.value) {
                                            var returnurl = "@Url.Action("Index", "ChitSubscriptionManagement")";
                                            window.location.href = returnurl;
                                        }
                                    });
                                }
                                else {
                                     Swal.fire({
                                        position: 'center',
                                        type: 'info',
                                        title: data,
                                        showConfirmButton: true,
                                        //timer: 5500
                                    }).then((result) => {
                                        if (result.value) {
                                            var returnurl = "@Url.Action("Index", "ChitSubscriptionManagement")";
                                            window.location.href = returnurl;
                                        }
                                    });
                                }

                            });
                    }
                    else if (result.dismiss === 'cancel') { return false; }
                });

                //var r = confirm("Are you sure to delete this record ?");
                //if (r == true) {
                //    var idx = $(this).attr('id');
                //    //base = window.location.origin;
                //    var baseUrl = $("#BaseUrl").data("baseurl");
                //    $.post(baseUrl + "/ChitSubscriptionManagement/Del",
                //        {
                //            id: idx, fld: "ChitSubscriptionManagement"
                //        },
                //        function (data, status) {
                //            if (data == "Deleted Successfully ...")
                //                location.replace(base + "/ChitSubscriptionManagement/Index");
                //            else if (data == "") alert("You are not authorize to Delete..!");
                //            else
                //                alert(data);
                //        });
                //}
                //return false;
            });//end

        });


    </script>

}






