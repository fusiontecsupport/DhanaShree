        function AssignLedger(obj) {
            var ahdid = 0;
            row = obj.parentNode.parentNode.rowIndex;
            row = row - 1;
            var $tableBody = $('#TDETAIL').find("tbody")
            $trCur = $tableBody.find("tr:eq(" + row + ")");

            var ahdid = $trCur.find(".TRANDREFID option:selected").val();
            var baseUrl = $("#BaseUrl").data("baseurl");
            //console.log(baseUrl);
            if (ahdid > 0) {
                var ajaxCallURL = baseUrl + '/Payment/GetLedgerDetail?id=' + ahdid;
                //alert(ajaxCallURL);
                $.ajax({
                    type: "GET",
                    url: ajaxCallURL,
                    async: false,
                    contentType: "application/json; charset=utf-8",
                    datatype: "json",
                    success: function (data) {
                        //console.log(data);
                        $trCur.find(".TRANDREFNAME").val(data[0].ACHEADDESC);
                        $trCur.find(".TRANDGREFID").val(data[0].CATEID);
                        $trCur.find(".ACHEADTYPE").val(data[0].ACHEADTYPE);
                    },
                    complete: function (data) {
                        //alert("ok");
                    },
                    error: function () {
                        alert("Content load failed.");
                    }
                });
            }
        }
        $(document).ready(function () {
            AssignOffice();
        });

        function AssignOffice() {
            var selofc = $(".TRANREFID option:selected").text();
            var selofcid = $(".TRANREFID option:selected").val();
            $(".TRANREFNAME").val(selofc);
            $(".LinkedOfficeID").val(selofcid);

        }
